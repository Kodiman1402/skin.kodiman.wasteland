<?xml version="1.0" encoding="UTF-8"?>
<timers>
	<timer>
		<name>autoclosevideoosd</name>
		<description>Timer to auto close the video OSD</description>
		<start reset="true">Window.IsActive(videoosd)</start>
		<reset>Window.IsActive(videoosd) + !System.IdleTime(1) + Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosevideoosd), 1)</reset>
		<stop>!Window.IsActive(videoosd) | Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosevideoosd), 5)</stop>
		<onstop>Dialog.Close(videoosd)</onstop>
	</timer>
	<timer>
		<name>autoclosedialogvideo</name>
		<description>Timer to auto close DialogFullScreenInfo.xml</description>
		<start reset="true">Window.IsActive(fullscreeninfo) + !String.IsEmpty(Window(10000).Property(short_dialog))</start>
		<reset>!System.IdleTime(1)</reset>
		<stop>!Window.IsActive(fullscreeninfo) | Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosedialogvideo), 9)</stop>
		<onstop condition="Window.IsActive(fullscreeninfo)">Dialog.Close(fullscreeninfo)</onstop>
	</timer>
	<timer>
		<name>checkmusicvideos</name>
		<description>Check whether an artist has music videos of any kind</description>
		<start reset="true">[Control.HasFocus(598) | Control.HasFocus(501) | Control.HasFocus(504) | Control.HasFocus(580) | Control.HasFocus(581) | Control.HasFocus(584) | Control.HasFocus(585) | Control.HasFocus(591) | Control.HasFocus(596) | Control.HasFocus(597) | Control.HasFocus(599) | Control.HasFocus(5850)] + Container.Content(artists) + System.IdleTime(2) + !String.IsEmpty(ListItem.DBID)</start>
		<onstart>SetProperty(audio.theaudiodb.helper.ArtistName,$INFO[ListItem.Artist],home)</onstart>
		<onstart>RunScript(plugin.audio.theaudiodb.helper,action=artist_musicvideo_count&amp;artistid=$INFO[ListItem.DBID])</onstart>
		<reset>!System.IdleTime(1)</reset>
		<stop>!Container.Content(artists) | Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(checkmusicvideos), 2)</stop>
	</timer>
	<timer>
		<name>autoclosemusicosd</name>
		<description>Timer to auto close the music OSD</description>
		<start reset="true">Window.IsActive(musicosd)</start>
		<reset>Window.IsActive(musicosd) + !System.IdleTime(1) + Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosemusicosd), 1)</reset>
		<stop>!Window.IsActive(musicosd) | Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosemusicosd), 5)</stop>
		<onstop>Dialog.Close(musicosd)</onstop>
	</timer>
	<timer>
		<name>autoclosemusicinfoosd</name>
		<description>Timer to auto close the music info dialog OSD</description>
		<start reset="true">Window.IsActive(1196)</start>
		<reset>Window.IsActive(1196) + !System.IdleTime(1) + Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosemusicinfoosd), 1)</reset>
		<stop>!Window.IsActive(1196) | Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autoclosemusicinfoosd), 5)</stop>
		<onstop>Dialog.Close(1196)</onstop>
	</timer>
	<timer>
		<name>autocloseplayercontrols</name>
		<description>Timer to auto close playercontrols</description>
		<start reset="true">Window.IsActive(playercontrols)</start>
		<reset>Window.IsActive(playercontrols) + !System.IdleTime(1) + Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autocloseplayercontrols), 1)</reset>
		<stop>!Window.IsActive(playercontrols) | Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(autocloseplayercontrols), 5)</stop>
		<onstop>Dialog.Close(playercontrols)</onstop>
	</timer>
	<timer>
		<name>autoclosevideointro</name>
		<description>Timer to auto close the video intro</description>
		<start reset="true">Window.IsActive(startup) + Skin.HasSetting(Enable.StartupIntro) + Player.Playing</start>
		<stop>!Window.IsActive(startup) | !Player.Playing</stop>
		<onstop condition="Window.IsActive(startup)">ReplaceWindow($INFO[System.StartupWindow])</onstop>
	</timer>
	<timer>
		<name>reopeninfomusic</name>
		<description>Open again Info dialog music window</description>
		<start reset="true">!String.IsEmpty(Window(10000).Property(back_to_info)) + Container.Content(artists) + [Control.HasFocus(598) | Control.HasFocus(584) | Control.HasFocus(596) | Control.HasFocus(591) | Control.HasFocus(597) | Control.HasFocus(504) | Control.HasFocus(501) | Control.HasFocus(580) | Control.HasFocus(581) | Control.HasFocus(599) | Control.HasFocus(593) | Control.HasFocus(5850) | Control.HasFocus(50)]</start>
		<onstart>Action(Info)</onstart>
		<onstart>ClearProperty(back_to_info,home)</onstart>
		<onstart>SetFocus(923)</onstart>
		<stop>Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(reopeninfomusic),2)</stop>
	</timer>
	<timer>
		<name>chooselanguage</name>
		<description>Timer to choose language and subtitles when playing starts</description>
		<start reset="true">Window.IsActive(fullscreenvideo) + [VideoPlayer.Content(movies) | VideoPlayer.Content(episodes)] + !Integer.IsGreater(VideoPlayer.Time,5) + Skin.HasSetting(choose.lang) + Player.Playing + Player.HasVideo + !String.IsEqual(VideoPlayer.Title,Window(10000).Property(pausing_movie)) + String.IsEmpty(Window(10000).Property(script.preshowexperience.running)) + Integer.IsGreater(VideoPlayer.Duration,420)</start>
		<onstart>Pause</onstart>
		<onstart>SetProperty(pausing_movie,$INFO[VideoPlayer.Title],home)</onstart>
		<onstart>SetProperty(short_dialog,true,home)</onstart>
		<onstart>Info</onstart>
		<stop>Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(chooselanguage),3)</stop>
	</timer>
	<timer>
		<name>customplaytrailer</name>
		<description>Timer to play trailers</description>
		<start reset="true">Skin.HasSetting(playTrailer) + String.IsEqual(Skin.String(StartTrailer),10) + !String.IsEmpty(ListItem.Trailer) + [Control.HasFocus(589) | Control.HasFocus(580) | Control.HasFocus(595) | Control.HasFocus(587) | Control.HasFocus(596) | Control.HasFocus(504) | Control.HasFocus(590) | Control.HasFocus(597) | Control.HasFocus(501) | Control.HasFocus(594) | Control.HasFocus(593)]</start>
		<reset>[!System.IdleTime(1) + Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(customplaytrailer), 1)] | String.IsEqual(Window(10000).Property(What_trailer),ListItem.Trailer)</reset>
		<stop>![Control.HasFocus(589) | Control.HasFocus(580) | Control.HasFocus(595) | Control.HasFocus(587) | Control.HasFocus(596) | Control.HasFocus(504) | Control.HasFocus(590) | Control.HasFocus(597) | Control.HasFocus(501) | Control.HasFocus(594) | Control.HasFocus(593)] | String.IsEqual(Window(10000).Property(What_trailer),ListItem.Trailer) | String.IsEmpty(ListItem.Trailer)</stop>
	</timer>
	<timer>
		<name>homemelody</name>
		<description>Timer to play melody in home menu</description>
		<start reset="true">Skin.HasSetting(melodyForHome) + [Window.IsActive(home) | Window.IsActive(settings) | Window.IsActive(skinsettings) | Window.IsActive(settingscategory.xml) | Window.IsActive(systeminfo) | Window.IsActive(profiles)] + !Player.Caching + !Window.IsActive(DialogButtonMenu.xml) + !Player.HasMedia + !Pvr.IsPlayingTv + !Pvr.IsPlayingRadio + !Player.IsInternetStream + !Window.IsActive(Favouritesbrowser) + !System.HasMediadvd</start>
		<stop>Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(homemelody),4) | [!Window.IsActive(home) + !Window.IsActive(settings) + !Window.IsActive(skinsettings) + !Window.IsActive(settingscategory.xml) + !Window.IsActive(systeminfo) + !Window.IsActive(profiles)] | Window.IsActive(DialogButtonMenu.xml)</stop>
		<reset>Integer.IsGreaterOrEqual(Skin.TimerElapsedSecs(homemelody),4) | [!Window.IsActive(home) + !Window.IsActive(settings) + !Window.IsActive(skinsettings) + !Window.IsActive(settingscategory.xml) + !Window.IsActive(systeminfo) + !Window.IsActive(profiles)] | Window.IsActive(DialogButtonMenu.xml)</reset>
	</timer>
