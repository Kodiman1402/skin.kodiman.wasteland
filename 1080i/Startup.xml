<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol>10</defaultcontrol>
	<onload condition="System.Platform.Windows + System.HasAddon(script.cu.lrclyrics) + System.AddonIsEnabled(script.cu.lrclyrics)">RunScript(script.aeon.tajo.helper,action=toggleaddons,addonid=script.cu.lrclyrics,enable=false)</onload>
	<onload condition="System.HasAddon(plugin.video.themoviedb.helper) + Skin.HasSetting(OnlineRating) + !Skin.HasSetting(TMDbHelper.Service)">Skin.ToggleSetting(TMDbHelper.Service)</onload>
	<onload condition="System.HasAddon(plugin.video.themoviedb.helper) + Skin.HasSetting(OnlineRating)">Skin.SetBool(TMDbHelper.DisableArtwork)</onload>
	<onload condition="String.IsEmpty(Skin.String(melodyPlaylist))">Skin.SetString(melodyPlaylist,special://skin/tajo_melodies)</onload>
	<onload condition="String.IsEmpty(Skin.String(videoIntro))">Skin.SetString(videoIntro,special://skin/extras/intro.mkv)</onload>
	<onload condition="String.IsEmpty(Skin.String(flat_back))">Skin.SetString(flat_back,FF2ccdc9)</onload>
	<onload condition="String.IsEmpty(Skin.String(theme_text))">Skin.SetString(theme_text,FF2ccdc9)</onload>
	<onload condition="String.IsEmpty(Skin.String(mark_color))">Skin.SetString(mark_color,FFff0303)</onload>
	<onload condition="String.IsEmpty(Skin.String(Delay_tr))">Skin.SetString(Delay_tr,5)</onload>
	<onload condition="String.IsEmpty(Skin.String(Overlay.Path))">Skin.SetString(Overlay.Path,overlays/1/)</onload>
	<onload condition="String.IsEmpty(Skin.String(first_scan))">RunScript(script.aeon.tajo.helper,action=multi_scan)</onload>
	<onload condition="String.IsEmpty(Skin.String(first_scan))">Skin.SetString(first_scan,True)</onload>
	<onload condition="String.IsEmpty(Skin.String(first_scan_music))">RunScript(script.aeon.tajo.helper,action=multi_scan_music)</onload>
	<onload condition="String.IsEmpty(Skin.String(first_scan_music))">Skin.SetString(first_scan_music,True)</onload>
	<onload condition="System.HasAddon(script.wikipedia)">Skin.SetString(WikiSearch," ")</onload>
	<onload>RunScript(script.aeon.tajo.helper,action=txtfile,path=special://skin/extras/credits.txt,header=$LOCALIZE[470],prop=MyCredits)</onload>
	<!-- Intro -->
	<onload condition="!System.HasPVRAddon + !Skin.HasSetting(Enable.StartupIntro)">ReplaceWindow($INFO[System.StartupWindow])</onload>
	<onunload condition="Skin.HasSetting(Enable.StartupIntro)">PlayerControl(Stop)</onunload>
	<onunload condition="Skin.HasSetting(Enable.StartupIntro)">Playlist.Clear</onunload>
	<controls>
		<control type="button" id="10">
			<include>HiddenObject</include>
			<onfocus condition="Skin.HasSetting(Enable.StartupIntro)">PlayMedia($INFO[Skin.String(videoIntro)],1)</onfocus>
			<onfocus condition="Skin.HasSetting(Enable.StartupIntro)">SetFocus(11)</onfocus>
			<onfocus condition="!Skin.HasSetting(Enable.StartupIntro)">SetFocus(12)</onfocus>
			<animation effect="fade" end="100" time="100">Focus</animation>
		</control>
		<control type="image">
			<visible>!Skin.HasSetting(Enable.StartupIntro)</visible>
			<animation type="WindowOpen" reversible="false">
				<effect type="slide" start="-1250,0" end="0,0" delay="2000" time="4000" tween="bounce" easing="out"/>
			</animation>
			<top>400</top>
			<left>555</left>
			<width>800</width>
			<height>240</height>
			<aspectratio>keep</aspectratio>
			<texture>aeon-tajo2.png</texture>
		</control>
		<control type="image">
			<visible>!Skin.HasSetting(Enable.StartupIntro)</visible>
			<animation type="WindowOpen" reversible="false">
				<effect type="slide" start="1250,0" end="0,0" delay="2000" time="4000" tween="bounce" easing="out"/>
			</animation>
			<top>400</top>
			<left>540</left>
			<width>840</width>
			<height>240</height>
			<aspectratio>keep</aspectratio>
			<colordiffuse>Skin.String(flat_back)</colordiffuse>
			<texture>aeon-tajo3.png</texture>
		</control>
		<control type="button" id="11">
			<include>HiddenObject</include>
			<onup>ReplaceWindow($INFO[System.StartupWindow])</onup>
			<ondown>ReplaceWindow($INFO[System.StartupWindow])</ondown>
			<onleft>ReplaceWindow($INFO[System.StartupWindow])</onleft>
			<onright>ReplaceWindow($INFO[System.StartupWindow])</onright>
			<onclick>ReplaceWindow($INFO[System.StartupWindow])</onclick>
		</control>
		<control type="button" id="12">
			<include>HiddenObject</include>
			<onfocus>ReplaceWindow($INFO[System.StartupWindow])</onfocus>
			<animation effect="fade" end="100" time="7000">Focus</animation>
		</control>
		<control type="group">
			<visible>Player.HasVideo</visible>
			<control type="image">
				<include>FullscreenDimensions</include>
				<texture>black.png</texture>
			</control>
			<control type="videowindow">
				<include>FullscreenDimensions</include>
			</control>
		</control>
	</controls>
</window>