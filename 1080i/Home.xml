<?xml version="1.0" encoding="utf-8"?>
<window>
	<defaultcontrol>9000</defaultcontrol>
	<backgroundcolor>background</backgroundcolor>
	<controls>
		<include>DefaultBackground</include>
		<include>TopBar</include>
		<!-- Wasteland Kodi Logo (oben links) -->
		<control type="image">
			<left>86</left>
			<top>40</top>
			<width>130</width>
			<height>170</height>
			<aspectratio>keep</aspectratio>
			<texture>/Users/oliverpfeffer/Library/Application Support/Kodi/addons/skin.kodiman.wasteland/extras/wasteland_kodi_logo.bmp</texture>
		</control>
		<control type="list" id="9000">
			<left>0</left>
			<top>240</top>
			<width>462</width>
			<height>800</height>
			<focusposition>0</focusposition>
			<scrolltime tween="cubic" easing="out">500</scrolltime>
			<itemlayout height="95">
				<control type="label">
					<left>104</left><top>0</top><height>95</height><width>560</width>
					<aligny>center</aligny><font>font37</font>
					<label>$INFO[ListItem.Label]</label>
					<shadowcolor>text_shadow</shadowcolor>
					<textcolor>FFB0A090</textcolor>
				</control>
			</itemlayout>
			<focusedlayout height="95">
				<control type="image">
					<left>0</left><top>0</top><width>462</width><height>95</height>
					<texture colordiffuse="button_focus">lists/focus.png</texture>
				</control>
				<!-- Glitch: Roter Kanal (links versetzt) -->
				<control type="label">
					<left>100</left><top>3</top><height>95</height><width>560</width>
					<aligny>center</aligny><font>font37</font>
					<label>$INFO[ListItem.Label]</label>
					<textcolor>FFFF0000</textcolor>
					<animation effect="fade" start="90" end="0" time="200" delay="0" condition="true">Conditional</animation>
					<animation effect="fade" start="0" end="90" time="300" delay="200">Visible</animation>
				</control>
				<!-- Glitch: Blauer Kanal (rechts versetzt) -->
				<control type="label">
					<left>108</left><top>0</top><height>95</height><width>560</width>
					<aligny>center</aligny><font>font37</font>
					<label>$INFO[ListItem.Label]</label>
					<textcolor>FF00CCFF</textcolor>
					<animation effect="fade" start="0" end="85" time="150" delay="100">Conditional</animation>
					<animation effect="fade" start="85" end="0" time="250" delay="300">Visible</animation>
				</control>
				<!-- Hauptlabel (weiss) -->
				<control type="label">
					<left>104</left><top>0</top><height>95</height><width>560</width>
					<aligny>center</aligny><font>font37</font>
					<label>$INFO[ListItem.Label]</label>
					<shadowcolor>text_shadow</shadowcolor>
					<textcolor>FFFFFFFF</textcolor>
				</control>
			</focusedlayout>
			<content>
				<item><label>Filme</label><onclick>ActivateWindow(Videos,videodb://movies/titles/,return)</onclick></item>
				<item><label>Serien</label><onclick>ActivateWindow(Videos,videodb://tvshows/titles/,return)</onclick></item>
				<item><label>Musik</label><onclick>ActivateWindow(Music,musicdb://songs/,return)</onclick></item>
				<item><label>Musikvideos</label><onclick>ActivateWindow(Videos,videodb://musicvideos/titles/,return)</onclick></item>
				<item><label>TV</label><onclick>ActivateWindow(TVChannels)</onclick></item>
				<item><label>Radio</label><onclick>ActivateWindow(RadioChannels)</onclick></item>
				<item><label>Spiele</label><onclick>ActivateWindow(Games)</onclick></item>
				<item><label>Addons</label><onclick>ActivateWindow(addonbrowser,addons://all/,return)</onclick></item>
				<item><label>Bilder</label><onclick>ActivateWindow(Pictures)</onclick></item>
				<item><label>Wetter</label><onclick>ActivateWindow(Weather)</onclick></item>
				<item><label>Einstellungen</label><onclick>ActivateWindow(settings)</onclick></item>
				<item><label>Beenden</label><onclick>Quit()</onclick></item>
			</content>
		</control>
		<!-- Scharfes Kodiman Logo -->
		<control type="image">
			<left>1760</left>
			<top>920</top>
			<width>100</width>
			<height>100</height>
			<texture>/Users/oliverpfeffer/Library/Application Support/Kodi/addons/skin.kodiman.wasteland/extras/coderman_logo.bmp</texture>
			<visible>true</visible>
		</control>
	</controls>
</window>
