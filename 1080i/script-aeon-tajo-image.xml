<?xml version="1.0" encoding="UTF-8"?>
<window>
	<controls>
		<control type="image">
			<include>FullscreenDimensions</include>
			<texture>black.png</texture>
		</control>
		<control type="list" id="1">
			<width>1920</width>
			<height>1080</height>
			<orientation>horizontal</orientation>
			<scrolltime>0</scrolltime>
			<pagecontrol>2</pagecontrol>
			<itemlayout/>
			<focusedlayout width="1920" height="1080"/>
		</control>
		<control type="image">
			<width>1920</width>
			<height>1080</height>
			<aspectratio>keep</aspectratio>
			<texture>$INFO[Container(1).ListItem.Icon]</texture>
			<fadetime>400</fadetime>
		</control>
		<control type="grouplist">
			<animation effect="fade" time="300" start="100" end="0" condition="System.IdleTime(2)">Conditional</animation>
			<left>1488</left>
			<top>1018</top>
			<width>400</width>
			<align>right</align>
			<orientation>horizontal</orientation>
			<itemgap>0</itemgap>
			<control type="label">
				<align>left</align>
				<width min="20" max="200">auto</width>
				<height>40</height>
				<textcolor>grey2</textcolor>
				<shadowcolor>black</shadowcolor>
				<font>fontDiscog</font>
				<label>$INFO[Container(1).CurrentItem]</label>
			</control>
			<control type="label">
				<align>left</align>
				<width min="20" max="200">auto</width>
				<height>52</height>
				<textcolor>grey2</textcolor>
				<shadowcolor>black</shadowcolor>
				<font>Font_bro</font>
				<label>/$INFO[Container(1).NumItems]</label>
			</control>
		</control>
		<control type="scrollbar" id="2">
			<include>ScrollBar_Horizontal2</include>
			<bottom>-8</bottom>
			<width>1920</width>
			<animation effect="fade" time="300" start="100" end="0" condition="System.IdleTime(2)">Conditional</animation>
		</control>
	</controls>
</window>