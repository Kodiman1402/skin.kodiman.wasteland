msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "შეცვალეთ ჰორიზონტალური სიების გადახვევა Aeon Tajo-ში.ნაგულისხმევი გადაახვევს სიებს ციკლში.\"შესწორებულია\" არის სიები დასაწყისით და დასასრულით."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "როდესაც ჩართულია, ტექსტი გადადის ავტომატურად.როდესაც გამორთულია, საჭიროა ხელით გადახვევა.გაითვალისწინეთ, რომ ტექსტური ყუთების უმეტესობას არ აქვს მექანიკური ღილაკი."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "აპროექტებს მიმდინარე სათამაშო ვიდეოს ფონზე, პანელების უკან."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "აპროექტებს ვიზუალიზაციას პანელების უკან ფონზე, როდესაც მუსიკა უკრავს."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "აჩვენებს ვიჯეტს მთავარ ეკრანზე მედიის ინფორმაციით, როდესაც მუსიკა უკრავს."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "აჩვენებს ვიჯეტს მთავარ ეკრანზე მედიის ინფორმაციით, როდესაც უკრავს ფილმი ან ეპიზოდი."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "ეს საშუალებას იძლევა მორგებული ჟანრის ფონი ვიდეობიბლიოთეკის ჟანრის კვანძის დათვალიერებისას.ფაილის სახელები უნდა შეესაბამებოდეს ჟანრის ეტიკეტს.გაფართოება უნდა იყოს .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "დააყენეთ ნაგულისხმევი შერჩევის მოქმედება ამ ელემენტის გასააქტიურებლად."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "ეს საშუალებას იძლევა მორგებული ჟანრის ფონი მუსიკალური ბიბლიოთეკის ჟანრის კვანძის დათვალიერებისას.ფაილის სახელები უნდა შეესაბამებოდეს ჟანრის ეტიკეტს.გაფართოება უნდა იყოს .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "აირჩიეთ წინასწარ დაყენებული ფონი ან დააყენეთ თქვენი საკუთარი სურათები მენიუს ელემენტების ფონად."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "აირჩიეთ დანამატები, დასაკრავი სიები ან ფავორიტები.აირჩიეთ „მორგებული“ კოდის ნებისმიერი ჩაშენებული ფუნქციისთვის.(http://kodi.wiki/?title=ჩაშენებული_ფუნქციების_სია)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "აღადგენს ყველა ზემოთ მოცემულ მნიშვნელობას ნაგულისხმევად."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo მთავარი მენიუს განლაგება"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "ეს პარამეტრი განსაზღვრავს რამდენი ელემენტი იქნება ხილული მთავარ მენიუში.ვარიანტები არის 3 ელემენტი ან 5 ელემენტი."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "აირჩიეთ ვიჯეტი მთავარ ეკრანზე გამოსატანად, რათა ბიბლიოთეკის შინაარსზე მარტივი წვდომა გქონდეთ."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "ვიდეოს სიუჟეტის უპირატესობა"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "აჩვენეთ სიუჟეტის მონახაზი ბიბლიოთეკის ხედებში და სრული სიუჟეტი ვიდეო ინფორმაციის დიალოგში ან პირიქით.უბრუნდება სრულ ნაკვეთს, თუ მონახაზი არ არის ხელმისაწვდომი."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "აირჩიეთ ელემენტი მთავარი მენიუს მარცხენა ზედა ნაწილში გამოსაჩენად"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "შეცვალეთ ადგილები მენიუს სხვა ელემენტით.ხსნის დიალოგს მენიუს ელემენტების სიით, რომელთაგან უნდა აირჩიოთ."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "აჩვენეთ RSS არხი ეკრანის ქვედა ან ზედა ნაწილში, მთავარი მენიუს პოზიციის მიხედვით.ამ პარამეტრის ჩართვა ქვემენიუს მუდმივად ხილულს ხდის."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "რთავს დამატებით ინფორმაციას სატელევიზიო შოუს ბიბლიოთეკაში, როგორიცაა სატელევიზიო შოუს სტატუსი, შემდეგი / უახლესი ეპიზოდი და ა.შ. დამოკიდებულია სატელევიზიო შოუს შემდეგი გაშვების დანამატზე."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "გადახვევისას ინფოპანელის დამალვა"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "მალავს საინფორმაციო პანელს Showcase-ისა და Landscape ხედისთვის (თუ გააქტიურებულია) ბიბლიოთეკაში გადაადგილებისას.დააყენეთ წამების რაოდენობა, რომ დაველოდოთ ინფოპანელის გამოჩენას, როდესაც გადახვევა შეჩერდება."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "კიოსკის რეჟიმი"

msgctxt "#31942"
msgid "Disables the slide out menu (media menu) in the library as well as certain buttons in the media information dialogs. (Requires restart to take effect)"
msgstr "გამორთავს slide out მენიუს (მედია მენიუ) ბიბლიოთეკაში, ისევე როგორც გარკვეული ღილაკები მედია ინფორმაციის დიალოგებში.(ითხოვს გადატვირთვას ძალაში შესვლისთვის)"

msgctxt "#31943"
msgid "Watched status indicator"
msgstr "ნანახი სტატუსის მაჩვენებელი"

msgctxt "#31944"
msgid "Choose which overlays to show on thumbs in icon based views. Note that the \"Resume\" flag takes precedent over any watched status."
msgstr "აირჩიეთ, რომელი გადაფარვები აჩვენოთ თითებზე ხატულებზე დაფუძნებულ ხედებში.გაითვალისწინეთ, რომ \"Resume\" დროშა არის პრეცედენტი ნებისმიერი ნანახი სტატუსის მიმართ."

msgctxt "#31945"
msgid "This toggles the layout of the List view. Default is a 7 item layout with extended info, \"Slim List\" is a 14 item, more basic layout"
msgstr "ეს ცვლის სიის ხედის განლაგებას.ნაგულისხმევი არის 7 ელემენტის განლაგება გაფართოებული ინფორმაციით, \"Slim List\" არის 14 ელემენტი, უფრო ძირითადი განლაგება"

