msgid "Changes the default Aeon Tajo background to another chosen by the user."
msgstr "Мења подразумевану Аеон Тајо позадину у другу коју одабере корисник."

msgctxt "#31212"
msgid "Current background path: "
msgstr "Тренутна путања у позадини:"

