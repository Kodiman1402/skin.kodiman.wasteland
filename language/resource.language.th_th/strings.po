msgid "MUSIC"
msgstr "เพลง"

msgctxt "#31957"
msgid "APPS"
msgstr "โปรแกรม"

msgctxt "#31958"
msgid "PLAY DISC"
msgstr "เล่นแผ่น"

msgctxt "#31959"
msgid "SYSTEM"
msgstr "ระบบ"

msgctxt "#31960"
msgid "CONCERTS"
msgstr "คอนเสิร์ต"

msgctxt "#31961"
msgid "Hide ratings in list views"
msgstr "ซ่อนเรตติ้งในมุมมองรายการ"

msgctxt "#31962"
msgid "This toggles the visibility of ratings in views of type List, LowList and TriPanel, except if sorted by rating."
msgstr "นี่จะสลับการปรากฎของเรตติ้งในมุมมองแบบ รายการ, รายการแบบต่ำ และสามแผงข้อมูล, ยกเว้นถ้าเรียงตามเรตติ้ง"

msgctxt "#31964"
msgid "NoTo"
msgstr ""

msgctxt "#31965"
msgid "Setup main menu"
msgstr "ตั้งค่าเมนูหลัก"

msgctxt "#31966"
msgid "Customize the main menu with widgets, backgrounds, submenus and statistics. Add your own custom main menu items."
msgstr "ปรับแต่งเมนูหลักด้วยวิดเจ็ต พื้นหลัง เมนูย่อย และสถิติเพิ่มรายการเมนูหลักที่คุณกำหนดเอง"

msgctxt "#31967"
msgid "Skin addons"
msgstr "ส่วนเสริมสกิน"

msgctxt "#31968"
msgid "Addons used to enhance Aeon Tajo."
msgstr "ส่วนเสริมใช้เพื่อปรับปรุง Aeon Tajo"

msgctxt "#31969"
msgid "Skin options"
msgstr "ตัวเลือกผิว"

