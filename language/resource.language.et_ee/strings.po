msgstr "Ilmateate andmete hankimine..."

msgctxt "#31910"
msgid "Map & Alerts"
msgstr "Kaart ja hoiatused"

msgctxt "#31911"
msgid "Setup the Aeon Tajo main menu"
msgstr "Seadistage Aeon Tajo peamenüü"

msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Kohandage peamenüüd vidinate, taustade ja statistikaga.Lisage oma kohandatud peamenüü üksused."

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Aeon Tajo peamenüü vertikaalasend"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Muutke peamenüü vertikaalset asendit.Vaikimisi on ekraani keskel."

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Horisontaalsete nimekirjade navigeerimislaad"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Muutke Aeon Tajos horisontaalsete loendite kerimisviisi.Vaikimisi kerib loendeid tsüklina.\"Fikseeritud\" on loendid alguse ja lõpuga."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Kui see on lubatud, kerib tekst automaatselt.Kui see on keelatud, on vajalik käsitsi kerimine.Pange tähele, et enamikul tekstikastidel pole käsitsi nuppu."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Kuvab esitatava video taustal, paneelide taga."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Kuvab visuaalid muusika esitamise ajal paneelide taha taustale."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Muusika esitamise ajal kuvatakse avakuval vidin meedia teabega."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Filmi või sarja esitamise ajal kuvatakse avakuval vidin meedia teabega."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "See lubab videokogu žanrisõlme sirvimisel kohandatud žanri taustad. Failinimed peavad vastama žanri sildile. Laiend peab olema .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Lubamiseks vali vaikimisi valitud toiming."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "See lubab muusikakogu žanrisõlme sirvimisel kohandatud žanri taustad. Failinimed peavad vastama žanri sildile. Laiend peab olema .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Vali mõni etteantud taustapiltidest või sea vabalt valitud pilt menüüvalikute taustaks."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Vali lisad, esitlusloendid või lemmikud. Mistahes Kodi sisseehitatud funktsiooni jaoks vali 'Isiklik'. (http://kodi.wiki/?title=List_of_Built_In_Functions)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Tühistab kõik ülalolevad valikud vaikeseadetele."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo peamenüü paigutus"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "See säte määrab, kui palju üksusi peamenüüs näha on.Valikud on 3 või 5 eset."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Vali avakuva vidin lihtsaks juurdepääsuks meediakogu sisule."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Video süžee eelistus"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Kuva süžee lühikokkuvõte meediakogu vaadetes ja täielik süžee infoaknas või vastupidi. Lühikokkuvõtte puudumisel kuvatakse täielik süžee."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Vali peamenüü vasakus ülaosas kuvatav üksus"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Vahetab kohad mõne teise menüükirjega. Avab dialoogi menüükirjete nimekirjaga."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "Kuva RSS kanal ekraani ala- või ülaosas sõltuvalt peamenüü asukohast. Selle sätte lubamisel on alammenüü püsivalt nähtav."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "Lubab seriaalide teegis lisateabe, nagu näiteks seriaali staatus, järgmine/viimane osa jne. Sõltub TV Show Next Aired lisast."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "Peida kerides infopaneel"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "Peidab teegis kerimise ajal esitlus- ja maastikuvaate teabepaneeli (kui see on aktiveeritud).Määrake sekundite aeg, mille jooksul kerimise peatamisel teabepaneel kuvatakse."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "Kioski režiim"

msgctxt "#31942"
msgid "Disables the slide out menu (media menu) in the library as well as certain buttons in the media information dialogs. (Requires restart to take effect)"
msgstr "Keelab teegis äraliugleva menüü (meedia menüü), samuti ka teatud nuppudelt meedia teabe dialoogis. (Jõustumiseks vajab taaskäivitamist)"

msgctxt "#31943"
msgid "Watched status indicator"
msgstr "Vaatamise seisundi näidik"

msgctxt "#31944"
msgid "Choose which overlays to show on thumbs in icon based views. Note that the \"Resume\" flag takes precedent over any watched status."
msgstr "Vali, millist pealiskihti kuvatakse pisipiltidel ikoonivaates. Pane tähele, et \"Jätka\" silt võtab üle kõik senised vaatamisstaatused."

msgctxt "#31945"
msgid "This toggles the layout of the List view. Default is a 7 item layout with extended info, \"Slim List\" is a 14 item, more basic layout"
msgstr "See muudab loendivaate laotust. Vaikimisi on 7 ühikuga loend koos lisainfoga, \"Tihe loend\" on 14 kirje ja tavapärasema laotusega"

