msgid "Overview"
msgstr "Genel Bakış"

msgctxt "#31301"
msgid "Last Updated"
msgstr "Son Güncelleme"

msgctxt "#31307"
msgid "Hide Fanart"
msgstr "Fanart'ı gizle"

msgctxt "#31308"
msgid "Next aired"
msgstr "Sonraki yayınlandı"

msgctxt "#31309"
msgid "Memory Used:"
msgstr "Kullanılan Bellek:"

msgctxt "#31310"
msgid "Available audio tracks"
msgstr "Mevcut ses parçaları"

msgctxt "#31317"
msgid "Set Fanart Path"
msgstr "Fanart Yolunu Ayarla"

msgctxt "#31320"
msgid "Last Logged In"
msgstr "Son Giriş Yapan"

msgctxt "#31321"
msgid "Karaoke Song Selector"
msgstr "Karaoke Şarkı Seçici"

msgctxt "#31328"
msgid "Recently Added"
msgstr "Son Eklenenler"

