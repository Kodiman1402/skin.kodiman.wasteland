msgid "Show similar movies in Shelf 3D view"
msgstr "Afficher des films similaires dans la vue Shelf 3D"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "Prévisions sur 36 heures"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Prévisions horaires"

