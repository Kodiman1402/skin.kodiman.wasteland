msgctxt "#31400"
msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]CONFIGURER LES PARAMÈTRES DE L'INTERFACE[/B][CR][CR]Changer le skin · Définir la langue et la région · Configurer les télécommandes[CR]Configurer un économiseur d'écran · Configurer le verrouillage principal"

msgctxt "#31401"
msgid "Menu - press 'OK'"
msgstr "Menu - appuyez sur « OK »"

msgctxt "#31402"
msgid "Enable startup video intro"
msgstr "Activer l'introduction vidéo de démarrage"

msgctxt "#31405"
msgid "[B]MONITOR YOUR SYSTEM[/B][CR][CR]Check out your hardware · Monitor CPU usage[CR]Check Kodi revision number"
msgstr "[B]SURVEILLEZ VOTRE SYSTÈME[/B][CR][CR]Vérifiez votre matériel · Surveillez l'utilisation de votre UCT[CR]Vérifiez le numéro de révision de Kodi"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]CONFIGURER LES PARAMÈTRES DU SYSTÈME[/B][CR][CR]Configurer et calibrer les écrans · Configurer la sortie audio · [CR]Définir les options d'économie d'énergie · Activer le débogage"

msgctxt "#31407"
msgid "[B]SETUP PROFILES[/B][CR][CR]Setup and manage user profiles · Enable login screen[CR]Change password · Add a profile picture"
msgstr "[B]PROFILS DE CONFIGURATION[/B][CR][CR]Configurer et gérer les profils utilisateur · Activer l'écran de connexion[CR]Changer le mot de passe · Ajouter une photo au profil"

msgctxt "#31409"
msgid "[B]CONFIGURE TV SETTINGS[/B][CR][CR]Change full screen info · Manage EPG data settings"
msgstr "[B]CONFIGURER LES RÉGLAGES DE LA TÉLÉ[/B][CR][CR]Changer les renseignements de plein écran · Gérer les données du GÉP"

msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]CONFIGURER LES PARAMÈTRES DES SERVICES[/B][CR][CR]Configurer le contrôle de Kodi par UPnP et HTTP · Configurer le partage de fichiers[CR]Activer Zéroconf · Configurer AirPlay"

msgctxt "#31412"
