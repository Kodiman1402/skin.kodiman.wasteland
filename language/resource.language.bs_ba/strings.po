msgctxt "#31400"
msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]KONFIGURIRAJTE POSTAVKE INTERFEJSA[/B][CR][CR]Promijenite izgled · Postavite jezik i regiju · Postavite daljinske upravljače[CR]Postavite čuvar ekrana · Postavite glavno zaključavanje"

msgctxt "#31401"
msgid "Menu - press 'OK'"
msgstr "Meni - pritisnite 'OK'"

msgctxt "#31402"
msgid "Enable startup video intro"
msgstr "Omogući uvodni video pri pokretanju"

msgctxt "#31405"
msgid "[B]MONITOR YOUR SYSTEM[/B][CR][CR]Check out your hardware · Monitor CPU usage[CR]Check Kodi revision number"
msgstr "[B]PRAĆITE SVOJ SISTEM[/B][CR][CR]Provjerite svoj hardver · Pratite korištenje CPU-a[CR]Provjerite Kodi broj revizije"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]KONFIGURIRAJTE SISTEMSKE POSTAVKE[/B][CR][CR]Postavite i kalibrirajte ekrane · Konfigurirajte audio izlaz · [CR]Postavite opcije uštede energije · Omogućite otklanjanje grešaka"

msgctxt "#31407"
msgid "[B]SETUP PROFILES[/B][CR][CR]Setup and manage user profiles · Enable login screen[CR]Change password · Add a profile picture"
msgstr "[B]POSTAVLJANJE PROFILA[/B][CR][CR]Podešavanje i upravljanje korisničkim profilima · Omogućavanje ekrana za prijavu[CR]Promjena lozinke · Dodajte sliku profila"

msgctxt "#31409"
msgid "[B]CONFIGURE TV SETTINGS[/B][CR][CR]Change full screen info · Manage EPG data settings"
msgstr "[B]KONFIGURIRAJTE TV POSTAVKE[/B][CR][CR]Promijenite informacije preko cijelog ekrana · Upravljajte postavkama podataka EPG-a"

msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]KONFIGURIRAJTE SERVISNE POSTAVKE[/B][CR][CR]Postavite kontrolu Kodi-a putem UPnP-a i HTTP-a · Konfigurirajte dijeljenje datoteka[CR]Omogućite Zeroconf · Konfigurirajte AirPlay"

msgctxt "#31412"
msgid "Select section"
msgstr "Odaberite odjeljak"

msgctxt "#31413"
msgid "Local subtitle available"
msgstr "Dostupan lokalni titl"

msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]KONFIGURIRAJ POSTAVKE PLAYERA[/B][CR][CR]Konfiguriraj reprodukciju videa · Konfiguriraj reprodukciju muzike · Konfiguriraj projekciju slajdova[CR]Konfiguriraj jezik videa i titlove"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]KONFIGURIRAJTE MEDIJSKE POSTAVKE[/B][CR][CR]Postavite zadanu akciju odabira · Konfigurirajte opcije liste datoteka · Konfigurirajte opcije metapodataka[CR]Upravljajte bazama podataka"

msgctxt "#31421"
msgid "Select your Kodi user profile[CR]to login and continue"
msgstr "Odaberite svoj Kodi korisnički profil[CR]da se prijavite i nastavite"

msgctxt "#31427"
msgid "Skin Shortcuts is responsible for handling all aspects of the main menu."
msgstr "Skin Shortcuts je odgovoran za rukovanje svim aspektima glavnog menija."

msgctxt "#31428"
msgid "The Grab Fanart script provides the random fanart slideshows for the main menu."
msgstr "Grab Fanart skripta pruža nasumične fanart projekcije slajdova za glavni meni."

msgctxt "#31429"
msgid "Library Data Provider is a service that runs in the background to provide library data for widgets and live backgrounds as well as playlist statistics for infolines."
msgstr "Dobavljač bibliotečkih podataka je usluga koja radi u pozadini kako bi pružila bibliotečke podatke za vidžete i pozadine uživo, kao i statistiku plejlista za infoline."

msgctxt "#31430"
msgid "Resource image addon for displaying the default white studio icons throughout the skin."
msgstr "Dodatak za slike resursa za prikazivanje zadanih bijelih studijskih ikona kroz kožu."

msgctxt "#31431"
msgid "Resource image addon for displaying the default white recording label icons throughout the skin."
msgstr "Dodatak za sliku resursa za prikazivanje zadanih bijelih ikona naljepnica za snimanje u cijeloj koži."

msgctxt "#31432"
msgid "Provides numerous Widget options and extended cast and crew metadata."
msgstr "Pruža brojne Widget opcije i proširene metapodatke o glumcima i ekipi."

msgctxt "#31433"
msgid "Skin Info Service is used to display movie set information throughout the skin."
msgstr "Skin Info Service se koristi za prikaz informacija o setu filma u cijeloj koži."

msgctxt "#31434"
msgid "Check MP3 Theme checks whether the user has put a theme.mp3 file in the corresponding movie/TV show folder to be played when browsing."
msgstr "Check MP3 Theme provjerava da li je korisnik stavio datoteku theme.mp3 u odgovarajući folder za film/TV emisiju za reprodukciju prilikom pretraživanja."

msgctxt "#31450"
msgid "  •  Open Settings "
msgstr "• Otvorite Postavke"

msgctxt "#31451"
msgid "  •  Click to Install"
msgstr "• Kliknite za instaliranje"

msgctxt "#31473"
msgid "Aeon Tajo Helper provides the data to display the cast for movies and TV shows."
msgstr "Aeon Tajo Helper pruža podatke za prikaz glumačke ekipe za filmove i TV emisije."

msgctxt "#31474"
msgid "CU LRC Lyrics is used to download, sync, and display lyrics during fullscreen music playback."
msgstr "CU LRC Lyrics se koristi za preuzimanje, sinhronizaciju i prikaz teksta tokom reprodukcije muzike preko celog ekrana."

msgctxt "#31475"
msgid "Play Trailer makes possible to play movie trailers through a context menu. "
msgstr "Play Trailer omogućava puštanje filmskih najava kroz kontekstni meni."

msgctxt "#31476"
msgid "Allows the use of Youtube to play trailers and other videos."
msgstr "Omogućava korištenje Youtubea za reprodukciju najava i drugih video zapisa."

msgctxt "#31477"
msgid "Provides some cast actress images to be shown in video views."
msgstr "Pruža neke glumačke slike glumica koje se prikazuju u video prikazima."

msgctxt "#31478"
msgid "Artist Slideshow is used to display artist fanart for both the home screen and during fullscreen music playback."
msgstr "Projekcija slajdova umjetnika se koristi za prikaz fanart umjetnika i za početni ekran i za vrijeme reprodukcije muzike preko cijelog ekrana."

msgctxt "#31479"
msgid "AutoCompletion provides suggestions to be selected while using the virtual keyboard."
msgstr "Automatsko dovršavanje pruža prijedloge za odabir dok koristite virtuelnu tastaturu."

msgctxt "#31480"
msgid "Library Editor Script uses JSON to directly edit your database information."
msgstr "Library Editor Script koristi JSON za direktno uređivanje informacija vaše baze podataka."

msgctxt "#31481"
msgid "Global Search makes possible to search among all the items (movies, TV shows, music, actors, etc.) in your collection."
msgstr "Globalna pretraga omogućava pretragu između svih stavki (filmova, TV emisija, muzike, glumaca itd.) u vašoj kolekciji."

msgctxt "#31501"
msgid "Channel group"
msgstr "Grupa kanala"

