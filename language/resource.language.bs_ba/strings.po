msgstr "NoTo"

msgctxt "#31965"
msgid "Setup main menu"
msgstr "Glavni meni podešavanja"

msgctxt "#31966"
msgid "Customize the main menu with widgets, backgrounds, submenus and statistics. Add your own custom main menu items."
msgstr "Prilagodite glavni meni sa widgetima, pozadinama, podmenijima i statistikom.Dodajte svoje vlastite prilagođene stavke glavnog menija."

msgctxt "#31967"
msgid "Skin addons"
