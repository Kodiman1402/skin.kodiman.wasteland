msgid "Available[CR]Groups"
msgstr "Dostupne[CR]Grupe"

msgctxt "#31511"
msgid "Channel Options"
msgstr "Opcije kanala"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Prikažite slične filmove u 3D prikazu polica"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "36-satna prognoza"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Prognoza po satu"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Prognoza za vikend"

msgctxt "#31904"
msgid "10 Day Forecast"
msgstr "Prognoza za 10 dana"

msgctxt "#31908"
msgid "Chance of Precipitation"
msgstr "Mogućnost padavina"

msgctxt "#31909"
msgid "Fetching forecast info..."
msgstr "Preuzimanje informacija o prognozi..."

msgctxt "#31910"
msgid "Map & Alerts"
msgstr "Mapa i upozorenja"

msgctxt "#31911"
msgid "Setup the Aeon Tajo main menu"
msgstr "Postavite Aeon Tajo glavni meni"

msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Prilagodite glavni meni sa widgetima, pozadinama i statistikom.Dodajte svoje vlastite prilagođene stavke glavnog menija."

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Vertikalna pozicija glavnog menija Aeon Tajo"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Promijenite vertikalni položaj glavnog menija.Podrazumevano je centrirano na ekranu."

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Stil navigacije za horizontalne liste"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Promijeni način na koji se horizontalne liste pomiču u Aeon Tajo. Podrazumevano će liste da se kreću u ciklusu. \"Fiksirano\" su liste sa početkom i krajem."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Kada je omogućeno, tekst se automatski pomiče.Kada je onemogućeno, potrebno je ručno pomicanje.Imajte na umu da većina tekstualnih okvira nema ručno dugme."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Projektuje video koji se trenutno reprodukuje na pozadinu iza panela."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Projektuje vizualizaciju na pozadini iza panela kada se pušta muzika."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Prikazuje widget na početnom ekranu sa informacijama o medijima kada svira muzika."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Prikazuje widget na početnom ekranu sa informacijama o medijima kada se igra film ili epizoda."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Ovo omogućava prilagođene žanrovske pozadine prilikom pregledavanja žanrovskog čvora videoteke.Nazivi datoteka trebaju odgovarati oznaci žanra.Ekstenzija mora biti .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Postavite zadanu akciju odabira da biste omogućili ovu stavku."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Ovo omogućava prilagođene žanrovske pozadine pri pretraživanju žanrovskog čvora muzičke biblioteke.Nazivi datoteka trebaju odgovarati oznaci žanra.Ekstenzija mora biti .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Odaberite jednu od unaprijed postavljenih pozadina ili postavite svoje slike kao pozadinu stavki menija."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Odaberite dodatke, liste za reprodukciju ili favorite.Odaberite "Prilagođeno" za bilo koju od ugrađenih funkcija Kodija.(http://kodi.wiki/?title=List_of_Built_In_Functions)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Vraća sve gore navedene vrijednosti na zadane vrijednosti."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo raspored glavnog menija"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Ova postavka definira koliko će stavki biti vidljivo u glavnom meniju.Opcije su 3 stavke ili 5 stavki."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Odaberite widget za prikaz na početnom ekranu kako biste imali lak pristup sadržaju iz biblioteke."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Preference video zapleta"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Prikaži skicu grafikona u prikazima biblioteke i punu sliku u dijalogu informacija o video zapisu ili obrnuto.Vraća se na punu sliku ako nema dostupnih nacrta."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Odaberite stavku za prikaz na lijevom vrhu glavnog izbornika"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Zamijenite mjesta pomoću druge stavke menija.Otvara dijalog sa listom stavki menija koje možete izabrati."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "Prikažite RSS feed na dnu ili na vrhu ekrana, u zavisnosti od pozicije glavnog menija.Omogućavanje ove postavke čini podmeni trajno vidljivim."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "Omogućava dodatne informacije u biblioteci TV emisija, kao što su status TV emisije, sljedeća/najnovija epizoda, itd. Zavisi od dodatka TV emisije Next Aired."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "Sakrijte infopanel pri pomicanju"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "Sakriva tablu sa informacijama za prikaz izložbe i pejzaž (ako je aktiviran) dok se krećete kroz biblioteku.Podesite količinu u sekundi za čekanje da se infopanel pojavi kada se pomeranje zaustavi."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "Način rada kioska"

msgctxt "#31942"
msgid "Disables the slide out menu (media menu) in the library as well as certain buttons in the media information dialogs. (Requires restart to take effect)"
msgstr "Onemogućuje izvlačenje menija (meni medija) u biblioteci, kao i određena dugmad u dijalozima informacija o medijima.(Zahtijeva ponovno pokretanje da stupi na snagu)"

msgctxt "#31943"
msgid "Watched status indicator"
msgstr "Indikator statusa gledanja"

msgctxt "#31944"
msgid "Choose which overlays to show on thumbs in icon based views. Note that the \"Resume\" flag takes precedent over any watched status."
msgstr "Izaberi koje preklope da prikažeš na sličicama u prikazima zasnovanim na ikonama. Napomena: \"Nastavi\" zastavica ima prednost nad bilo kojim statusom gledanja."

msgctxt "#31945"
msgid "This toggles the layout of the List view. Default is a 7 item layout with extended info, \"Slim List\" is a 14 item, more basic layout"
msgstr "Ovo mijenja raspored prikaza Liste. Podrazumevano je raspored od 7 stavki sa proširenim informacijama, \"Tanka lista\" je raspored od 14 stavki, osnovniji"

