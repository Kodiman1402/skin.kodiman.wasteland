msgstr "Automatski otvara birač zvuka i titlova pri pokretanju reprodukcije filmova i epizoda, omogućavajući vam da vidite koji su zapisi aktivni i promijenite ih izravno prije nastavka."

msgctxt "#31425"
msgid "Search music video links for songs not in your library"
msgstr "Traži veze muzičkih videozapisa za pjesme koje nisu u vašoj biblioteci"

msgctxt "#31426"
msgid "Similar artists on your library"
msgstr "Slični izvođači u vašoj biblioteci"

msgctxt "#31435"
msgid "Albums by this artist in your library"
msgstr "Albumi ovog izvođača u vašoj biblioteci"

msgctxt "#31436"
msgid "Online info from TheAudioDB.com for music"
msgstr "Online informacije s TheAudioDB.com za muziku"

msgctxt "#31437"
msgid "Get online information from TheAudioDB.com on the artist and album information screen"
msgstr "Preuzmi online informacije s TheAudioDB.com na ekranu s informacijama o izvođaču i albumu"

msgctxt "#31438"
msgid "TheAudioDb Helper supplies online data and artwork to display enhanced details for artists and music albums."
msgstr "TheAudioDb Helper pruža online podatke i slike za prikaz proširenih detalja o izvođačima i muzičkim albumima."

