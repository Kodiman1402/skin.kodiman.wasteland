msgstr "Núverandi bakgrunnsslóð:"

msgctxt "#31213"
msgid "Reset skin default background"
msgstr "Endurstilla sjálfgefna bakgrunn húðarinnar"

msgctxt "#31214"
msgid "Resets the default background provided with Aeon Tajo."
msgstr "Endurstillir sjálfgefna bakgrunninn sem fylgir Aeon Tajo."

msgctxt "#31215"
msgid "Show the coloured version of the icons rather than the monochrome version."
msgstr "Sýndu lituðu útgáfuna af táknunum frekar en einlita útgáfuna."

msgctxt "#31216"
msgid "Displays background and fanart images with a subtle motion effect across the screen."
msgstr "Sýnir bakgrunns- og fanart myndir með fíngerðum hreyfiáhrifum yfir skjáinn."

msgctxt "#31217"
msgid "Displays a list in the video views featuring thumbnail images of the main actors from the movie or TV show's cast."
msgstr "Sýnir lista í myndskeiðaskoðunum með smámyndum af aðalleikurum úr leikarahópi kvikmyndarinnar eða sjónvarpsþáttarins."

msgctxt "#31218"
msgid "Search the Studio Icons add-on for logo images of the film studios of the movie/TV show, and if found, display them while browsing the video views."
msgstr "Leitaðu að Studio Icons viðbótinni að lógómyndum af kvikmyndaverum kvikmyndarinnar/sjónvarpsþáttarins, og ef þær finnast skaltu sýna þær á meðan þú skoðar myndskeiðin."

msgctxt "#31219"
msgid "Search for the album's record label logo using the RecordLabel Icons addon, and if found, display it when browsing the music album views."
msgstr "Leitaðu að merki plötuútgefanda plötunnar með því að nota RecordLabel Icons viðbótina og ef þú finnur það skaltu sýna það þegar þú skoðar tónlistarplöturnar."

msgctxt "#31220"
