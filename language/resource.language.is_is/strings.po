msgid "Delete Group"
msgstr "Eyða hópi"

msgctxt "#31506"
msgid "Available[CR]Groups"
msgstr "Tiltækir[CR]hópar"

msgctxt "#31511"
msgid "Channel Options"
msgstr "Rásir Valmöguleikar"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Sýndu svipaðar kvikmyndir í hillu 3D útsýni"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "36 klst veðurspá"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Veðurspá fyrir klukkustundir"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Veðurspá helgarinnar"

msgctxt "#31904"
msgid "10 Day Forecast"
msgstr "10 daga veðurspá"

msgctxt "#31908"
msgid "Chance of Precipitation"
msgstr "Líkur á úrkomu"

msgctxt "#31909"
msgid "Fetching forecast info..."
msgstr "Næ í veðurspá..."

msgctxt "#31910"
msgid "Map & Alerts"
msgstr "Kort & Viðvaranir"

msgctxt "#31911"
msgid "Setup the Aeon Tajo main menu"
msgstr "Setja upp Aeon Tajo aðavalmynd"

msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Sérsníða græjur í aðalvalmynd, bakgrunn og tölulegar upplýsingar. Bæta við eigin sérsniðnum hlutum í aðalvalmynd."

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Aeon Tajo aðalvalmynd lóðrétt staða"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Breyttu lóðréttri stöðu aðalvalmyndarinnar.Sjálfgefið er fyrir miðju á skjánum."

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Leiðarstýring fyrir lárétta lista"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Breyta því hvernig láréttur listi færist í Aeon Tajo. Sjálfgefin stilling færir listann í hringi. \"Fixed\" eru listar með upphafi og enda."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Þegar það er virkt flettir textinn sjálfkrafa.Þegar slökkt er á handvirkri skrunun er krafist.Athugaðu að flestir textareitir eru ekki með handvirkan hnapp."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Sýnir myndefni í bakgrunni fyrir aftan slá."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Sýnir myndskreytingu í bakgrunni fyrir aftan slá þegar tónlist er spiluð."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Sýnir græju á heimaskjá með upplýsingum þegar tónlist er spiluð."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Sýnir græju á heimaskjá með upplýsingum þegar kvikmynd eða þáttur er í spilun."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Þetta virkjar sérsniðna bakgrunns flokka þegar flett er í gegnum myndefnissafn í flokka ham. Skráanöfn eiga vera þau sömu og flokka merking. Endingar skrá verða að vera .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Stillið sjálfgefið val til að virkja þennan hlut."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Þetta virkjar sérsniðna bakgrunns flokka þegar flett er í gegnum myndefnissafn í flokka ham. Skráanöfn eiga vera þau sömu og flokka merking. Endingar skrá verða að vera .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Veljið einn af forstilltu bakgrunnunum eða eigin ljósmynd sem bakgrunns valmynd hlutar."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Veljið viðbót, spilunarlista eða uppáhald. Veljið 'Custom' fyrir innbyggða Kodi's stillingu. (http://kodi.wiki/?title=List_of_Built_In_Functions)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Endursetjið allar stillingar hér að ofan sem sjálfgefnar."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo uppsetning aðalvalmyndar"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Þessi stilling segir til um hversu margir hlutir eru sýnilegir í aðalvalmynd. Möguleikarnir eru 3 eða 5 hlutir."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Veljið græju til að sýna á heimaskjá fyrir auðveldan aðgang að gögnum úr safni."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Myndefnis söguþráður, stillingar"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Sýna úrdrátt á söguþræði í safnaham og allan söguþráð í upplýsingaglugga myndar eða öfugt. Til vara sýnir allan söguþráð er úrdráttur er ekki til."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Veldu atriði til að birta efst vinstra megin á aðalvalmyndinni"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Skiptið um staðsetningu við annan hlut í valmynd. Opnar glugga með lista af hlutum til að velja úr."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "Sýnið RSS slá efst eða neðst á skjá, eftir staðsetningu aðalvalmyndar. Með því að virkja þessa stillingu verður undirvalmynd alltaf sýnileg."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "Virkjar auka upplýsingar í sjónvarpsþáttasafni eins og stöðu þátta, næsti / síðasti þáttur osfrv. Er háð TV Show Next Aired viðbót."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "Fela upplýsingaslá þegar flett er"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "Felur uppl. slá fyrir Sýniumslag og Lárétt sýn (ef virkjað) meðan flett er í gegnum safnið. Stillið hversu margar sekúndu töf er þangað til upplýsingaslá birtist eftir að flettingu er hætt."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "Sjoppustilling"

