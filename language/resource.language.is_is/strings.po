msgid "Options"
msgstr "Valmöguleikar"

msgctxt "#31210"
msgid "Select another image as default background"
msgstr "Veldu aðra mynd sem sjálfgefinn bakgrunn"

msgctxt "#31211"
msgid "Changes the default Aeon Tajo background to another chosen by the user."
msgstr "Breytir sjálfgefnum Aeon Tajo bakgrunni í annan sem notandinn velur."

msgctxt "#31212"
