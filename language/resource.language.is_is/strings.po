msgctxt "#31400"
msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]STILLA VIÐVITISSTILLINGAR[/B][CR][CR]Breyttu húðinni · Stilltu tungumál og svæði · Setja upp fjarstýringar[CR]Setja upp skjávarann · Setja upp aðallás"

msgctxt "#31401"
msgid "Menu - press 'OK'"
msgstr "Valmynd - ýttu á 'OK'"

msgctxt "#31402"
msgid "Enable startup video intro"
msgstr "Virkja kynningarmyndband við ræsingu"

msgctxt "#31405"
msgid "[B]MONITOR YOUR SYSTEM[/B][CR][CR]Check out your hardware · Monitor CPU usage[CR]Check Kodi revision number"
msgstr "[B]YFIRSÝN KERFI[/B][CR][CR]Athuga vélbúnað Fylgjast með örgjafa notkun[CR]Athuga útgáfunúmer Kodi"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]STILLA KERFSSTILLINGAR[/B][CR][CR]Setja upp og kvarða skjái · Stilla hljóðúttak · [CR]Stilla orkusparnaðarvalkosti · Virkja villuleit"

msgctxt "#31407"
msgid "[B]SETUP PROFILES[/B][CR][CR]Setup and manage user profiles · Enable login screen[CR]Change password · Add a profile picture"
msgstr "[B]SETJA UPP NOTENDASÍÐU[/B][CR][CR]Setja upp og stilla notendasíðu · Virkja innskráningar skjá[CR]Breyta lykilorði · Bæta við notenda mynd"

msgctxt "#31409"
msgid "[B]CONFIGURE TV SETTINGS[/B][CR][CR]Change full screen info · Manage EPG data settings"
msgstr "[B]SJÓNVARPS STILLINGAR [/B][CR][CR]Breyta uppl. í fullum skjá · Stjórna EPG gagna stillingum"

msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Uppsetning á stjórnun Kodi með UPnP og HTTP · Setja upp skráardeilingu[CR]Virkja Zeroconf · Stilla AirPlay"

msgctxt "#31412"
msgid "Select section"
msgstr "Velja aðgerð"

msgctxt "#31413"
msgid "Local subtitle available"
msgstr "Texti í boði á tölvu"

msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]STILLSTILLA PLAYERASTILLINGAR[/B][CR][CR]Stilla myndspilun · Stilla tónlistarspilun · Stilla myndasýningu[CR]Stilla myndmál og texta"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]STILLA MEÐMILSSTILLINGAR[/B][CR][CR]Velja sjálfgefna valaðgerð · Stilla valkosti skráalista · Stilla valkosti lýsigagna[CR]Hafa umsjón með gagnagrunnum"

msgctxt "#31421"
msgid "Select your Kodi user profile[CR]to login and continue"
msgstr "Veldu Kodi notanda[CR]til að skrá þig inn og halda áfram"

msgctxt "#31427"
msgid "Skin Shortcuts is responsible for handling all aspects of the main menu."
msgstr "Skin Shortcuts ber ábyrgð á að meðhöndla alla þætti aðalvalmyndarinnar."

msgctxt "#31428"
msgid "The Grab Fanart script provides the random fanart slideshows for the main menu."
msgstr "Grab Fanart handritið býður upp á handahófskenndar fanart skyggnusýningar fyrir aðalvalmyndina."

msgctxt "#31429"
msgid "Library Data Provider is a service that runs in the background to provide library data for widgets and live backgrounds as well as playlist statistics for infolines."
msgstr "Library Data Provider er þjónusta sem keyrir í bakgrunni til að veita bókasafnsgögn fyrir græjur og lifandi bakgrunn sem og lagalistatölfræði fyrir upplýsingalínur."

msgctxt "#31430"
msgid "Resource image addon for displaying the default white studio icons throughout the skin."
msgstr "Auðlindamyndaviðbót til að sýna sjálfgefna hvít stúdíótákn um húðina."

msgctxt "#31431"
msgid "Resource image addon for displaying the default white recording label icons throughout the skin."
msgstr "Auðlindamyndaviðbót til að sýna sjálfgefna hvíta upptökumerkistákn um húðina."

msgctxt "#31432"
msgid "Provides numerous Widget options and extended cast and crew metadata."
msgstr "Býður upp á fjölmarga græjuvalkosti og útvíkkuð lýsigögn leikara og áhafnar."

msgctxt "#31433"
msgid "Skin Info Service is used to display movie set information throughout the skin."
msgstr "Húðupplýsingaþjónusta er notuð til að birta upplýsingar um kvikmyndasett um húðina."

msgctxt "#31434"
msgid "Check MP3 Theme checks whether the user has put a theme.mp3 file in the corresponding movie/TV show folder to be played when browsing."
msgstr "Athugaðu MP3 Þema athugar hvort notandinn hafi sett theme.mp3 skrá í samsvarandi kvikmynda-/sjónvarpsþáttamöppu til að spila þegar hann vafrar."

msgctxt "#31450"
msgid "  •  Open Settings "
msgstr "  •  Opna stillingar "

msgctxt "#31451"
msgid "  •  Click to Install"
msgstr "• Smelltu til að setja upp"

msgctxt "#31473"
msgid "Aeon Tajo Helper provides the data to display the cast for movies and TV shows."
msgstr "Aeon Tajo Helper veitir gögnin til að sýna leikarahópinn fyrir kvikmyndir og sjónvarpsþætti."

msgctxt "#31474"
msgid "CU LRC Lyrics is used to download, sync, and display lyrics during fullscreen music playback."
msgstr "CU LRC textar eru notaðir til að hlaða niður, samstilla og birta texta við tónlistarspilun á öllum skjánum."

msgctxt "#31475"
msgid "Play Trailer makes possible to play movie trailers through a context menu. "
msgstr "Play Trailer gerir kleift að spila kvikmyndastiklur í gegnum samhengisvalmynd."

msgctxt "#31476"
msgid "Allows the use of Youtube to play trailers and other videos."
msgstr "Leyfir notkun Youtube til að spila stiklur og önnur myndbönd."

msgctxt "#31477"
msgid "Provides some cast actress images to be shown in video views."
msgstr "Veitir nokkrar leikaramyndir til að sýna í myndskeiðum."

msgctxt "#31478"
msgid "Artist Slideshow is used to display artist fanart for both the home screen and during fullscreen music playback."
msgstr "Skyggnusýning listamanns er notuð til að sýna listamann aðdáendur bæði á heimaskjánum og meðan á tónlistarspilun stendur á öllum skjánum."

msgctxt "#31479"
msgid "AutoCompletion provides suggestions to be selected while using the virtual keyboard."
msgstr "Sjálfvirk útfylling veitir tillögur til að velja á meðan sýndarlyklaborðið er notað."

msgctxt "#31480"
msgid "Library Editor Script uses JSON to directly edit your database information."
msgstr "Library Editor Script notar JSON til að breyta gagnagrunnsupplýsingunum þínum beint."

msgctxt "#31481"
msgid "Global Search makes possible to search among all the items (movies, TV shows, music, actors, etc.) in your collection."
msgstr "Alþjóðleg leit gerir kleift að leita meðal allra hluta (kvikmynda, sjónvarpsþátta, tónlist, leikara osfrv.) í safninu þínu."

msgctxt "#31501"
msgid "Channel group"
msgstr "Rás hópur"

msgctxt "#31502"
msgid "Live TV"
msgstr "Bein sjónvarpsútsending"

msgctxt "#31503"
msgid "Add Group"
msgstr "Bæta við hópi"

msgctxt "#31504"
msgid "Rename Group"
msgstr "Endurnefna hóp"

