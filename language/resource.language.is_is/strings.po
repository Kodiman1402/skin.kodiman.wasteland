msgstr "Fela smámyndir leikarans"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "Sýndu aðeins lista yfir nöfn leikaranna, í stað þess að innihalda einnig smámyndir þeirra."

msgctxt "#31250"
