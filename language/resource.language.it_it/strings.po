msgid "Available[CR]Groups"
msgstr "Gruppi[CR]disponibili"

msgctxt "#31511"
msgid "Channel Options"
msgstr "Opzioni canale"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Mostra film simili nella vista Shelf 3D"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "Previsioni a 36 ore"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Previsioni orarie"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Previsioni fine settimana"

