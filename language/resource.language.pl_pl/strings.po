msgstr "Ukryj miniatury aktorów"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "Pokazuj tylko listę imion aktorów, bez ich miniatur."

msgctxt "#31250"
msgid "Automatic Full Screen when playing music"
msgstr "Automatyczny pełny ekran podczas odtwarzania muzyki"

msgctxt "#31251"
msgid "Don't play melodies while in Home Screen"
msgstr "Nie odtwarzaj melodii na ekranie głównym"

