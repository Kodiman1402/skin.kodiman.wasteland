msgstr "KONCERTY"

msgctxt "#31961"
msgid "Hide ratings in list views"
msgstr "Ukrywaj ocenę w widokach list"

msgctxt "#31962"
msgid "This toggles the visibility of ratings in views of type List, LowList and TriPanel, except if sorted by rating."
msgstr "Ta opcja przełącza widoczność oceny w widokach typu Lista, Lista Niska i Trzy panele, za wyjątkiem sortowania po ocenie."

