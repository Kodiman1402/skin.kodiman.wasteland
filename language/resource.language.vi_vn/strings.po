msgstr "Hiển thị tiện ích nhạc tại nhà"

msgctxt "#31198"
msgid "Show home video widget"
msgstr "Hiển thị tiện ích video gia đình"

msgctxt "#31199"
msgid "Colours, marks and home screen"
msgstr "Màu sắc, nhãn hiệu và màn hình chính"

msgctxt "#31200"
msgid "Is used to choose among different Kodi resource image pack to weather artwork and icons."
msgstr "Được sử dụng để chọn trong số các gói hình ảnh tài nguyên Kodi khác nhau cho các biểu tượng và tác phẩm nghệ thuật thời tiết."

msgctxt "#31201"
msgid "Performance impact"
msgstr "Tác động hiệu suất"

msgctxt "#31202"
msgid "Plays music in the background while in Home and Settings screens. A default song collection is provided, but a different song folder can be used."
msgstr "Phát nhạc ở chế độ nền khi ở màn hình Chính và Cài đặt.Bộ sưu tập bài hát mặc định được cung cấp nhưng có thể sử dụng thư mục bài hát khác."

msgctxt "#31203"
msgid "Select your own folder to use as background music. Make sure that it only contains music files."
msgstr "Chọn thư mục của riêng bạn để sử dụng làm nhạc nền.Hãy chắc chắn rằng nó chỉ chứa các tập tin nhạc."

msgctxt "#31204"
msgid "When enabled, widgets linked to each home menu item will appear automatically. If disabled, widgets remain hidden until the corresponding arrow key is pressed."
msgstr "Khi được bật, các tiện ích được liên kết với từng mục menu chính sẽ tự động xuất hiện.Nếu bị tắt, các tiện ích sẽ vẫn bị ẩn cho đến khi nhấn phím mũi tên tương ứng."

msgctxt "#31205"
msgid "Lyrics Source"
msgstr "Nguồn lyric"

msgctxt "#31206"
msgid "Customization"
msgstr "Tùy chỉnh"

msgctxt "#31207"
msgid "Views"
msgstr "Lượt xem"

msgctxt "#31208"
msgid "Home screen"
msgstr "Màn hình chính"

msgctxt "#31209"
msgid "Options"
msgstr "Tùy chọn"

msgctxt "#31210"
msgid "Select another image as default background"
msgstr "Chọn hình ảnh khác làm nền mặc định"

msgctxt "#31211"
msgid "Changes the default Aeon Tajo background to another chosen by the user."
msgstr "Thay đổi nền Aeon Tajo mặc định sang nền khác do người dùng chọn."

msgctxt "#31212"
msgid "Current background path: "
msgstr "Đường dẫn nền hiện tại:"

msgctxt "#31213"
msgid "Reset skin default background"
msgstr "Đặt lại nền mặc định của da"

msgctxt "#31214"
msgid "Resets the default background provided with Aeon Tajo."
msgstr "Đặt lại nền mặc định được cung cấp bởi Aeon Tajo."

msgctxt "#31215"
msgid "Show the coloured version of the icons rather than the monochrome version."
msgstr "Hiển thị phiên bản màu của các biểu tượng thay vì phiên bản đơn sắc."

msgctxt "#31216"
msgid "Displays background and fanart images with a subtle motion effect across the screen."
msgstr "Hiển thị hình ảnh nền và fanart với hiệu ứng chuyển động tinh tế trên màn hình."

msgctxt "#31217"
msgid "Displays a list in the video views featuring thumbnail images of the main actors from the movie or TV show's cast."
msgstr "Hiển thị danh sách trong chế độ xem video có hình ảnh thu nhỏ của các diễn viên chính trong dàn diễn viên của phim hoặc chương trình truyền hình."

msgctxt "#31218"
msgid "Search the Studio Icons add-on for logo images of the film studios of the movie/TV show, and if found, display them while browsing the video views."
msgstr "Tìm kiếm tiện ích bổ sung Biểu tượng Studio để tìm hình ảnh logo của xưởng phim của bộ phim/chương trình truyền hình và nếu tìm thấy, hãy hiển thị chúng trong khi duyệt qua các chế độ xem video."

msgctxt "#31219"
msgid "Search for the album's record label logo using the RecordLabel Icons addon, and if found, display it when browsing the music album views."
msgstr "Tìm kiếm biểu tượng hãng thu âm của album bằng cách sử dụng tiện ích bổ sung Biểu tượng RecordLabel và nếu tìm thấy, hãy hiển thị biểu tượng đó khi duyệt các chế độ xem album nhạc."

msgctxt "#31220"
msgid "Show rating"
msgstr "Hiển thị xếp hạng"

msgctxt "#31221"
msgid "Show artist clearart"
msgstr "Hiển thị nghệ sĩ rõ ràng"

msgctxt "#31222"
msgid "Show CD"
msgstr "Hiển thị đĩa CD"

msgctxt "#31223"
msgid "Show Time"
msgstr "Hiển thị thời gian"

msgctxt "#31224"
msgid "Animated posters"
msgstr "Áp phích hoạt hình"

msgctxt "#31225"
msgid "Normal posters"
msgstr "Áp phích bình thường"

msgctxt "#31226"
msgid "Extra posters"
msgstr "Áp phích bổ sung"

msgctxt "#31227"
msgid "Sets the transparency level of the home menu widgets."
msgstr "Đặt mức độ trong suốt của các tiện ích menu chính."

msgctxt "#31228"
msgid "Displays main menu options in a vertical layout instead of a horizontal one."
msgstr "Hiển thị các tùy chọn menu chính theo bố cục dọc thay vì bố cục ngang."

msgctxt "#31229"
msgid "Set another video file as startup intro"
msgstr "Đặt tệp video khác làm phần giới thiệu khởi động"

msgctxt "#31230"
msgid "Choose another video file to play when Kodi starts instead of Aeon Tajo default. It's recommended to choose a short one. To stop playback and start using Kodi right away, click or press any arrow key."
msgstr "Chọn một tệp video khác để phát khi Kodi khởi động thay vì mặc định của Aeon Tajo.Nên chọn một cái ngắn.Để dừng phát lại và bắt đầu sử dụng Kodi ngay lập tức, hãy nhấp hoặc nhấn bất kỳ phím mũi tên nào."

msgctxt "#31231"
msgid "Plays an intro video when launching Kodi"
msgstr "Phát video giới thiệu khi khởi chạy Kodi"

msgctxt "#31232"
msgid "Clear current intro video file and back to default"
msgstr "Xóa tệp video giới thiệu hiện tại và quay lại mặc định"

msgctxt "#31233"
msgid "Clear the intro video file selected by the user and back to Aeon Tajo's default."
msgstr "Xóa tệp video giới thiệu do người dùng chọn và quay về mặc định của Aeon Tajo."

msgctxt "#31234"
msgid "Adds a layer that simulates falling snow on all Kodi screens, with four available intensity levels."
msgstr "Thêm lớp mô phỏng tuyết rơi trên tất cả các màn hình Kodi, với bốn mức cường độ có sẵn."

msgctxt "#31235"
msgid "Override the current home menu backgrounds with this one"
msgstr "Ghi đè hình nền menu chính hiện tại bằng hình nền này"

msgctxt "#31236"
msgid "The background selections made in the Setup Main Menu screen will be preserved. Disabling this option will restore all previous backgrounds. This option is particularly designed for use during special seasons."
msgstr "Các lựa chọn nền được thực hiện trong màn hình Menu chính Cài đặt sẽ được giữ nguyên.Tắt tùy chọn này sẽ khôi phục tất cả các hình nền trước đó.Tùy chọn này được thiết kế đặc biệt để sử dụng trong các mùa đặc biệt."

