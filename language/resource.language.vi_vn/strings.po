msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]CÀI ĐẶT GIAO DIỆN CẤU HÌNH[/B][CR][CR]Thay đổi giao diện · Đặt ngôn ngữ và vùng · Thiết lập điều khiển từ xa[CR]Thiết lập trình bảo vệ màn hình · Thiết lập khóa chính"

msgctxt "#31401"
msgid "Menu - press 'OK'"
msgstr "Trình đơn - nhấn 'OK'"

