msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Thay đổi cách cuộn danh sách ngang trong Aeon Tajo.Mặc định sẽ cuộn danh sách theo một chu kỳ.\"Đã sửa\" là các danh sách có phần đầu và phần cuối."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Khi kích hoạt văn bản sẽ tự động cuộn.Khi cần phải cuộn thủ công.Lưu ý rằng hầu hết các hộp văn bản đều không có nút thủ công."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Chiếu video đang phát trên nền phía sau bảng điều khiển."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Chiếu hình ảnh trực quan lên nền phía sau bảng điều khiển khi phát nhạc."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Hiển thị một widget trên Màn Hình Chính với những thông tin của chúng khi đang phát nhạc."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Hiển thị một tiện ích trên Màn hình chính với thông tin đa phương tiện khi một bộ phim hoặc tập phim đang phát."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Điều này cho phép nền thể loại tùy chỉnh khi duyệt qua nút thể loại của thư viện video.Tên tập tin phải phù hợp với nhãn thể loại.Phần mở rộng phải là .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Đặt hành động chọn mặc định để bật mục này."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Điều này cho phép nền thể loại tùy chỉnh khi duyệt qua nút thể loại của thư viện nhạc.Tên tập tin phải phù hợp với nhãn thể loại.Phần mở rộng phải là .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Chọn một trong các hình nền cài sẵn hoặc đặt hình ảnh của riêng bạn làm nền của các mục menu."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Chọn tiện ích bổ sung, danh sách phát hoặc mục yêu thích.Chọn 'Tùy chỉnh' cho bất kỳ chức năng tích hợp nào của Kodi.(http://kodi.wiki/?title=List_of_Built_In_Functions)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Đặt lại tất cả các giá trị trên về mặc định của chúng."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Bố cục menu chính của Aeon Tajo"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Cài đặt này xác định số lượng mục sẽ hiển thị trên menu chính.Tùy chọn là 3 mục hoặc 5 mục."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Chọn một widget hiển thị trên Màn Hình Chính để dễ dàng truy cập nội dung của chúng từ thư viện."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Tùy chọn cốt truyện video"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Hiển thị phác thảo cốt truyện trong chế độ xem thư viện và cốt truyện đầy đủ trong hộp thoại thông tin video hoặc ngược lại.Trở lại cốt truyện đầy đủ nếu không có đề cương."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Chọn một mục để hiển thị phía trên bên trái của thực đơn chính"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Đổi địa điểm bằng một mục menu khác.Mở hộp thoại có danh sách các mục menu để chọn."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "Hiển thị RSS phía dưới hoặc trên đỉnh màn hình, phụ thuộc vào vị trí thực đơn chính. Kích hoạt mục này sẽ làm cho thực đơn phụ luôn xuất hiện."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "Cho phép bổ sung thông tin trong thư viện chương trình truyền hình, như trạng thái chương trình truyền hình, tập tiếp theo/mới nhất, v.v. Tùy thuộc vào tiện ích bổ sung TV Show Next Aired."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "Ẩn bảng thông tin khi cuộn"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "Ẩn bảng thông tin cho chế độ xem Trưng bày và Chế độ xem ngang (nếu được kích hoạt) trong khi cuộn qua thư viện.Đặt số giây để chờ bảng thông tin xuất hiện khi dừng cuộn."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "Chế độ Kiosk"

msgctxt "#31942"
msgid "Disables the slide out menu (media menu) in the library as well as certain buttons in the media information dialogs. (Requires restart to take effect)"
msgstr "Tắt menu trượt ra (menu phương tiện) trong thư viện cũng như các nút nhất định trong hộp thoại thông tin phương tiện.(Yêu cầu khởi động lại để có hiệu lực)"

msgctxt "#31943"
msgid "Watched status indicator"
msgstr "Dấu hiệu trạng thái Đã xem"

msgctxt "#31944"
msgid "Choose which overlays to show on thumbs in icon based views. Note that the \"Resume\" flag takes precedent over any watched status."
msgstr "Chọn lớp phủ nào sẽ hiển thị trên ngón tay cái trong chế độ xem dựa trên biểu tượng.Lưu ý rằng cờ \"Tiếp tục\" được ưu tiên hơn mọi trạng thái đã xem."

msgctxt "#31945"
msgid "This toggles the layout of the List view. Default is a 7 item layout with extended info, \"Slim List\" is a 14 item, more basic layout"
msgstr "Điều này sẽ bật/tắt bố cục kiểu xem Danh sách. Mặc định là bố cục có 7 mục với thông tin mở rộng, \"Danh sách Nhỏ\" là 14 mục, nhiều hơn bố cục mặc định."

