msgstr "Bật phần giới thiệu video khởi động"

msgctxt "#31405"
msgid "[B]MONITOR YOUR SYSTEM[/B][CR][CR]Check out your hardware · Monitor CPU usage[CR]Check Kodi revision number"
msgstr "[B] GIÁM SÁT HỆ THỐNG CỦA BẠN[/B][CR][CR]Kiểm tra phần cứng của bạn · Giám sát việc sử dụng CPU[CR]Kiểm tra số phiên bản Kodi"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]CÀI ĐẶT HỆ THỐNG CẤU HÌNH[/B][CR][CR]Thiết lập và hiệu chỉnh màn hình · Định cấu hình đầu ra âm thanh · [CR]Đặt tùy chọn tiết kiệm năng lượng · Bật gỡ lỗi"

msgctxt "#31407"
msgid "[B]SETUP PROFILES[/B][CR][CR]Setup and manage user profiles · Enable login screen[CR]Change password · Add a profile picture"
msgstr "[B]SETUP PROFILES[/B][CR][CR]Thiết lập và quản lý hồ sơ người dùng · Kích hoạt màn hình đăng nhập[CR]Thay đổi mật khẩu · Thêm ảnh hồ sơ"

msgctxt "#31409"
msgid "[B]CONFIGURE TV SETTINGS[/B][CR][CR]Change full screen info · Manage EPG data settings"
msgstr "[B]HIỆU CHỈNH TV[/B][CR][CR]Thay đội thông tin · Quản lý các hiệu chỉnh của dữ liệu EPG"

msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]TUỲ CHỈNH CÀI ĐẶT DỊCH VỤ[/B][CR][CR]Cài đặt điều khiển Kodi thông qua UPnP và HTTP · Tuỳ chỉnh chia sẻ file[CR]Bật Zeroconf · Tuỳ chỉnh AirPlay"

msgctxt "#31412"
msgid "Select section"
msgstr "Chọn phần"

msgctxt "#31413"
msgid "Local subtitle available"
msgstr "Phụ đề sẵn có trong máy"

msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]CẤU HÌNH CÀI ĐẶT MÁY PHÁT[/B][CR][CR]Định cấu hình phát lại video · Định cấu hình phát lại nhạc · Định cấu hình trình chiếu hình ảnh[CR]Định cấu hình ngôn ngữ và phụ đề video"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]CẤU HÌNH CÀI ĐẶT MEDIA[/B][CR][CR]Đặt hành động chọn mặc định · Định cấu hình tùy chọn danh sách tệp · Định cấu hình tùy chọn siêu dữ liệu[CR]Quản lý cơ sở dữ liệu"

msgctxt "#31421"
msgid "Select your Kodi user profile[CR]to login and continue"
msgstr "Chọn hồ sơ người dùng Kodi[CR]để đăng nhập và tiếp tục"

msgctxt "#31427"
msgid "Skin Shortcuts is responsible for handling all aspects of the main menu."
msgstr "Skin Phím tắt chịu trách nhiệm xử lý tất cả các khía cạnh của menu chính."

msgctxt "#31428"
msgid "The Grab Fanart script provides the random fanart slideshows for the main menu."
msgstr "Tập lệnh Grab Fanart cung cấp các trình chiếu fanart ngẫu nhiên cho menu chính."

msgctxt "#31429"
msgid "Library Data Provider is a service that runs in the background to provide library data for widgets and live backgrounds as well as playlist statistics for infolines."
msgstr "Nhà cung cấp dữ liệu thư viện là một dịch vụ chạy ở chế độ nền để cung cấp dữ liệu thư viện cho các tiện ích và hình nền trực tiếp cũng như số liệu thống kê danh sách phát cho các dòng thông tin."

msgctxt "#31430"
msgid "Resource image addon for displaying the default white studio icons throughout the skin."
msgstr "Phần bổ trợ hình ảnh tài nguyên để hiển thị các biểu tượng studio màu trắng mặc định trên toàn bộ giao diện."

msgctxt "#31431"
msgid "Resource image addon for displaying the default white recording label icons throughout the skin."
msgstr "Phần bổ trợ hình ảnh tài nguyên để hiển thị các biểu tượng nhãn ghi màu trắng mặc định trên toàn bộ giao diện."

msgctxt "#31432"
msgid "Provides numerous Widget options and extended cast and crew metadata."
msgstr "Cung cấp nhiều tùy chọn Widget và siêu dữ liệu mở rộng về dàn diễn viên và đoàn làm phim."

msgctxt "#31433"
msgid "Skin Info Service is used to display movie set information throughout the skin."
msgstr "Dịch vụ Thông tin Da được sử dụng để hiển thị thông tin về bộ phim trên toàn bộ da."

msgctxt "#31434"
msgid "Check MP3 Theme checks whether the user has put a theme.mp3 file in the corresponding movie/TV show folder to be played when browsing."
msgstr "Kiểm tra Chủ đề MP3 để kiểm tra xem người dùng đã đặt tệp theme.mp3 vào thư mục phim/chương trình truyền hình tương ứng để phát khi duyệt hay chưa."

msgctxt "#31450"
msgid "  •  Open Settings "
msgstr "• Mở Cài đặt"

msgctxt "#31451"
msgid "  •  Click to Install"
msgstr "• Bấm để cài đặt"

msgctxt "#31473"
msgid "Aeon Tajo Helper provides the data to display the cast for movies and TV shows."
msgstr "Aeon Tajo Helper cung cấp dữ liệu để hiển thị dàn diễn viên cho phim và chương trình truyền hình."

msgctxt "#31474"
msgid "CU LRC Lyrics is used to download, sync, and display lyrics during fullscreen music playback."
msgstr "CU LRC Lyrics được sử dụng để tải xuống, đồng bộ và hiển thị lời bài hát trong khi phát nhạc toàn màn hình."

msgctxt "#31475"
msgid "Play Trailer makes possible to play movie trailers through a context menu. "
msgstr "Play Trailer cho phép phát đoạn giới thiệu phim thông qua menu ngữ cảnh."

msgctxt "#31476"
msgid "Allows the use of Youtube to play trailers and other videos."
msgstr "Cho phép sử dụng Youtube để phát đoạn giới thiệu và các video khác."

msgctxt "#31477"
msgid "Provides some cast actress images to be shown in video views."
msgstr "Cung cấp một số hình ảnh diễn viên được hiển thị trong chế độ xem video."

msgctxt "#31478"
msgid "Artist Slideshow is used to display artist fanart for both the home screen and during fullscreen music playback."
msgstr "Trình chiếu nghệ sĩ được sử dụng để hiển thị tác phẩm nghệ thuật của nghệ sĩ cho cả màn hình chính và trong khi phát nhạc toàn màn hình."

msgctxt "#31479"
msgid "AutoCompletion provides suggestions to be selected while using the virtual keyboard."
msgstr "Tự động hoàn thành cung cấp các đề xuất để chọn trong khi sử dụng bàn phím ảo."

msgctxt "#31480"
msgid "Library Editor Script uses JSON to directly edit your database information."
msgstr "Tập lệnh biên tập thư viện sử dụng JSON để chỉnh sửa trực tiếp thông tin cơ sở dữ liệu của bạn."

msgctxt "#31481"
msgid "Global Search makes possible to search among all the items (movies, TV shows, music, actors, etc.) in your collection."
msgstr "Tìm kiếm Toàn cầu cho phép tìm kiếm trong số tất cả các mục (phim, chương trình truyền hình, âm nhạc, diễn viên, v.v.) trong bộ sưu tập của bạn."

