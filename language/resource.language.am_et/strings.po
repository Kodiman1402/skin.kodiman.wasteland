msgctxt "#31218"
msgid "Search the Studio Icons add-on for logo images of the film studios of the movie/TV show, and if found, display them while browsing the video views."
msgstr "የፊልሙን/የቲቪ ትዕይንቱን የፊልም ስቱዲዮዎች የአርማ ምስሎችን ለማግኘት የስቱዲዮ አዶዎችን ተጨማሪ ይፈልጉ እና ከተገኙ የቪዲዮ እይታዎችን እያሰሱ ያሳዩዋቸው።"

msgctxt "#31219"
msgid "Search for the album's record label logo using the RecordLabel Icons addon, and if found, display it when browsing the music album views."
msgstr "የ RecordLabel Icons አዶን በመጠቀም የአልበሙን ሪከርድ መለያ አርማ ይፈልጉ እና ከተገኘ የሙዚቃ አልበም እይታዎችን ሲቃኙ ያሳዩት።"

msgctxt "#31220"
msgid "Show rating"
msgstr "ደረጃ አሳይ"

msgctxt "#31221"
msgid "Show artist clearart"
msgstr "አርቲስት clearart አሳይ"

msgctxt "#31222"
msgid "Show CD"
msgstr "ሲዲ አሳይ"

msgctxt "#31223"
msgid "Show Time"
msgstr "ጊዜ አሳይ"

msgctxt "#31224"
msgid "Animated posters"
msgstr "የታነሙ ፖስተሮች"

msgctxt "#31225"
msgid "Normal posters"
msgstr "መደበኛ ፖስተሮች"

msgctxt "#31226"
msgid "Extra posters"
msgstr "ተጨማሪ ፖስተሮች"

msgctxt "#31227"
msgid "Sets the transparency level of the home menu widgets."
msgstr "የቤት ሜኑ መግብሮችን ግልጽነት ያዘጋጃል።"

msgctxt "#31228"
msgid "Displays main menu options in a vertical layout instead of a horizontal one."
msgstr "በአግድም ሳይሆን በአቀባዊ አቀማመጥ የዋና ምናሌ አማራጮችን ያሳያል።"

msgctxt "#31229"
msgid "Set another video file as startup intro"
msgstr "ሌላ የቪዲዮ ፋይል እንደ ማስጀመሪያ መግቢያ ያዘጋጁ"

msgctxt "#31230"
msgid "Choose another video file to play when Kodi starts instead of Aeon Tajo default. It's recommended to choose a short one. To stop playback and start using Kodi right away, click or press any arrow key."
msgstr "ከAeon Tajo ነባሪ ይልቅ Kodi ሲጀምር የሚጫወተው ሌላ የቪዲዮ ፋይል ይምረጡ።አጭር ለመምረጥ ይመከራል.መልሶ ማጫወት ለማቆም እና Kodiን ወዲያውኑ መጠቀም ለመጀመር ማንኛውንም የቀስት ቁልፍ ጠቅ ያድርጉ ወይም ይጫኑ።"

msgctxt "#31231"
msgid "Plays an intro video when launching Kodi"
msgstr "Kodi ን ሲያስጀምር የመግቢያ ቪዲዮ ይጫወታል"

msgctxt "#31232"
msgid "Clear current intro video file and back to default"
msgstr "የአሁኑን የመግቢያ ቪዲዮ ፋይል ያጽዱ እና ወደ ነባሪ ይመለሱ"

msgctxt "#31233"
msgid "Clear the intro video file selected by the user and back to Aeon Tajo's default."
msgstr "በተጠቃሚው የተመረጠውን የመግቢያ ቪዲዮ ፋይል ያጽዱ እና ወደ Aeon Tajo ነባሪ ይመለሱ።"

msgctxt "#31234"
msgid "Adds a layer that simulates falling snow on all Kodi screens, with four available intensity levels."
msgstr "በሁሉም የኮዲ ስክሪኖች ላይ የሚወርደውን በረዶ የሚያስመስል ሽፋን ያክላል፣ በአራት የሚገኙ የጥንካሬ ደረጃዎች።"

msgctxt "#31235"
msgid "Override the current home menu backgrounds with this one"
msgstr "የአሁኑን የቤት ሜኑ ዳራ በዚህ ይሽሩት"

msgctxt "#31236"
msgid "The background selections made in the Setup Main Menu screen will be preserved. Disabling this option will restore all previous backgrounds. This option is particularly designed for use during special seasons."
msgstr "በማዋቀር ዋና ሜኑ ማያ ገጽ ላይ የተደረጉት የጀርባ ምርጫዎች ይጠበቃሉ።ይህንን አማራጭ ማሰናከል ሁሉንም የቀድሞ ዳራዎችን ወደነበረበት ይመልሳል።ይህ አማራጭ በተለይ በልዩ ወቅቶች ውስጥ ለመጠቀም የተነደፈ ነው."

msgctxt "#31237"
msgid "No impact"
msgstr "ምንም ተጽዕኖ የለም።"

msgctxt "#31238"
msgid "Very small"
msgstr "በጣም ትንሽ"

msgctxt "#31239"
msgid "Small"
msgstr "ትንሽ"

msgctxt "#31240"
msgid "Moderate"
msgstr "መጠነኛ"

msgctxt "#31241"
msgid "Pixel format"
msgstr "የፒክሰል ቅርጸት"

msgctxt "#31242"
msgid "System rendering speed"
msgstr "የስርዓት አወጣጥ ፍጥነት"

msgctxt "#31243"
msgid "Hide actor's thumbnails"
msgstr "የተዋንያን ድንክዬዎችን ደብቅ"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "ድንክዬዎቻቸውን ከማካተት ይልቅ የተዋንያንን ስም ዝርዝር ብቻ አሳይ።"

msgctxt "#31250"
msgid "Automatic Full Screen when playing music"
msgstr "ሙዚቃ በሚጫወትበት ጊዜ ራስ-ሰር ሙሉ ማያ ገጽ"

msgctxt "#31251"
msgid "Don't play melodies while in Home Screen"
msgstr "በመነሻ ስክሪን ላይ እያሉ ዜማዎችን አይጫወቱ"

msgctxt "#31252"
msgid "Always show home screen widgets"
msgstr "ሁልጊዜ የመነሻ ማያ ገጽ መግብሮችን አሳይ"

msgctxt "#31253"
msgid "Choose user audio playlist *.m3u (max.10 songs)"
msgstr "የተጠቃሚ የድምጽ አጫዋች ዝርዝር *.m3u (ከፍተኛው 10 ዘፈኖች) ምረጥ"

msgctxt "#31254"
msgid "Clear user playlist (back to default)"
msgstr "የተጠቃሚ አጫዋች ዝርዝር አጽዳ (ወደ ነባሪ ይመለሱ)"

