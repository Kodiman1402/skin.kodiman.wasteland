msgid "System rendering speed"
msgstr "Kasi ya utoaji wa mfumo"

msgctxt "#31243"
msgid "Hide actor's thumbnails"
msgstr "Ficha vijipicha vya mwigizaji"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "Onyesha tu orodha ya majina ya waigizaji, badala ya kujumuisha pia vijipicha vyao."

msgctxt "#31250"
msgid "Automatic Full Screen when playing music"
msgstr "Skrini Kamili ya Kiotomatiki unapocheza muziki"

msgctxt "#31251"
msgid "Don't play melodies while in Home Screen"
msgstr "Usicheze nyimbo ukiwa kwenye Skrini ya Nyumbani"

msgctxt "#31252"
msgid "Always show home screen widgets"
msgstr "Onyesha wijeti za skrini ya kwanza kila wakati"

msgctxt "#31253"
msgid "Choose user audio playlist *.m3u (max.10 songs)"
msgstr "Chagua orodha ya kucheza ya sauti ya mtumiaji *.m3u (nyimbo zisizozidi 10)"

