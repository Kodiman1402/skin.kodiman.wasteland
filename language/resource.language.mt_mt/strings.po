msgctxt "#31209"
msgid "Options"
msgstr "Għażliet"

msgctxt "#31210"
msgid "Select another image as default background"
msgstr "Agħżel immaġni oħra bħala sfond default"

msgctxt "#31211"
msgid "Changes the default Aeon Tajo background to another chosen by the user."
msgstr "Tibdel l-isfond default Aeon Tajo għal ieħor magħżul mill-utent."

msgctxt "#31212"
msgid "Current background path: "
msgstr "Mogħdija fl-isfond attwali:"

msgctxt "#31213"
msgid "Reset skin default background"
msgstr "Irrisettja l-isfond default tal-ġilda"

msgctxt "#31214"
msgid "Resets the default background provided with Aeon Tajo."
msgstr "Resets l-isfond default ipprovdut b'Aeon Tajo."

msgctxt "#31215"
msgid "Show the coloured version of the icons rather than the monochrome version."
msgstr "Uri l-verżjoni kkulurita tal-ikoni aktar milli l-verżjoni monokroma."

msgctxt "#31216"
msgid "Displays background and fanart images with a subtle motion effect across the screen."
msgstr "Juri immaġni fl-isfond u fanart b'effett ta 'moviment sottili madwar l-iskrin."

msgctxt "#31217"
msgid "Displays a list in the video views featuring thumbnail images of the main actors from the movie or TV show's cast."
msgstr "Juri lista fil-fehmiet tal-vidjow li jinkludu immaġini miniaturi tal-atturi ewlenin mill-cast tal-film jew tal-ispettaklu tat-TV."

msgctxt "#31218"
msgid "Search the Studio Icons add-on for logo images of the film studios of the movie/TV show, and if found, display them while browsing the video views."
msgstr "Fittex l-Ikoni Studio add-on għal immaġini tal-logo tal-istudjos tal-films tal-film/programm tat-TV, u jekk jinstab, urihom waqt li qed tfittex l-opinjonijiet tal-vidjo."

msgctxt "#31219"
msgid "Search for the album's record label logo using the RecordLabel Icons addon, and if found, display it when browsing the music album views."
msgstr "Fittex il-logo tat-tikketta tad-diski tal-album billi tuża l-addon RecordLabel Icons, u jekk tinstab, uriha meta tibbrawżja l-fehmiet tal-album tal-mużika."

msgctxt "#31220"
msgid "Show rating"
msgstr "Uri l-klassifikazzjoni"

msgctxt "#31221"
msgid "Show artist clearart"
msgstr "Uri clearart artist"

msgctxt "#31222"
msgid "Show CD"
msgstr "Uri CD"

msgctxt "#31223"
msgid "Show Time"
msgstr "Uri l-Ħin"

msgctxt "#31224"
msgid "Animated posters"
msgstr "Posters animati"

msgctxt "#31225"
msgid "Normal posters"
msgstr "Posters normali"

msgctxt "#31226"
msgid "Extra posters"
msgstr "Posters żejda"

msgctxt "#31227"
msgid "Sets the transparency level of the home menu widgets."
msgstr "Issettja l-livell ta' trasparenza tal-widgets tal-menu tad-dar."

msgctxt "#31228"
msgid "Displays main menu options in a vertical layout instead of a horizontal one."
msgstr "Juri l-għażliet tal-menu prinċipali f'tqassim vertikali minflok wieħed orizzontali."

msgctxt "#31229"
msgid "Set another video file as startup intro"
msgstr "Issettja fajl ieħor tal-vidjo bħala intro tal-istartjar"

msgctxt "#31230"
msgid "Choose another video file to play when Kodi starts instead of Aeon Tajo default. It's recommended to choose a short one. To stop playback and start using Kodi right away, click or press any arrow key."
msgstr "Agħżel video file ieħor biex tilgħab meta jibda Kodi minflok Aeon Tajo default.Huwa rakkomandat li tagħżel waħda qasira.Biex twaqqaf il-qari u tibda tuża Kodi mill-ewwel, ikklikkja jew agħfas kwalunkwe ċavetta tal-vleġġa."

msgctxt "#31231"
msgid "Plays an intro video when launching Kodi"
msgstr "Jilgħab vidjow ta' introduzzjoni meta jniedi Kodi"

msgctxt "#31232"
msgid "Clear current intro video file and back to default"
msgstr "Ċara l-fajl tal-vidjo tal-introduzzjoni kurrenti u lura għall-inadempjenza"

msgctxt "#31233"
msgid "Clear the intro video file selected by the user and back to Aeon Tajo's default."
msgstr "Ċara l-fajl tal-vidjo tal-introduzzjoni magħżul mill-utent u lura għall-inadempjenza ta 'Aeon Tajo."

msgctxt "#31234"
msgid "Adds a layer that simulates falling snow on all Kodi screens, with four available intensity levels."
msgstr "Iżżid saff li jissimula l-borra nieżla fuq l-iskrins kollha Kodi, b'erba 'livelli ta' intensità disponibbli."

msgctxt "#31235"
msgid "Override the current home menu backgrounds with this one"
msgstr "Ikkalkola l-isfondi attwali tal-menu tad-dar b'dan wieħed"

msgctxt "#31236"
msgid "The background selections made in the Setup Main Menu screen will be preserved. Disabling this option will restore all previous backgrounds. This option is particularly designed for use during special seasons."
msgstr "L-għażliet fl-isfond magħmula fl-iskrin Setup Main Menu se jiġu ppreservati.Id-diżattivazzjoni ta' din l-għażla tirrestawra l-isfondi preċedenti kollha.Din l-għażla hija partikolarment iddisinjata għall-użu matul staġuni speċjali."

msgctxt "#31237"
msgid "No impact"
msgstr "L-ebda impatt"

msgctxt "#31238"
msgid "Very small"
msgstr "Żgħir ħafna"

msgctxt "#31239"
msgid "Small"
msgstr "Żgħir"

