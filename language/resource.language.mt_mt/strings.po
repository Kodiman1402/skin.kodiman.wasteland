msgstr "Ħarsa ġenerali"

msgctxt "#31301"
msgid "Last Updated"
msgstr "Aġġornata l-aħħar"

msgctxt "#31307"
msgid "Hide Fanart"
msgstr "Aħbi Fanart"

msgctxt "#31308"
msgid "Next aired"
msgstr "Li jmiss imxandra"

msgctxt "#31309"
msgid "Memory Used:"
msgstr "Memorja Użata:"

msgctxt "#31310"
msgid "Available audio tracks"
msgstr "Tracks awdjo disponibbli"

msgctxt "#31317"
msgid "Set Fanart Path"
msgstr "Issettja Fanart Path"

msgctxt "#31320"
msgid "Last Logged In"
msgstr "Dħalt l-aħħar"

