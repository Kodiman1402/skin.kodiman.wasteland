msgstr "Veloċità tar-rendi tas-sistema"

msgctxt "#31243"
msgid "Hide actor's thumbnails"
msgstr "Aħbi thumbnails tal-attur"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "Uri biss lista tal-ismijiet tal-atturi, minflok tinkludi wkoll il-minjieri tagħhom."

msgctxt "#31250"
msgid "Automatic Full Screen when playing music"
msgstr "Awtomatiku Full Screen meta idoqq il-mużika"

msgctxt "#31251"
msgid "Don't play melodies while in Home Screen"
msgstr "Tdoqqx melodiji waqt li tkun fil-Home Screen"

msgctxt "#31252"
msgid "Always show home screen widgets"
msgstr "Dejjem uri widgets tal-iskrin tad-dar"

msgctxt "#31253"
msgid "Choose user audio playlist *.m3u (max.10 songs)"
msgstr "Agħżel il-playlist tal-awdjo tal-utent *.m3u (max.10 kanzunetti)"

msgctxt "#31254"
