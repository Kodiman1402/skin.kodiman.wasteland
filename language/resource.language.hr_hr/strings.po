msgid "Automatic Full Screen when playing music"
msgstr "Automatski cijeli zaslon tijekom reprodukcije glazbe"

msgctxt "#31251"
msgid "Don't play melodies while in Home Screen"
msgstr "Ne puštajte melodije dok ste na početnom zaslonu"

msgctxt "#31252"
