msgstr "Brzina renderiranja sustava"

msgctxt "#31243"
msgid "Hide actor's thumbnails"
msgstr "Sakrij minijature glumca"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "Prikažite samo popis imena glumaca, umjesto uključivanja njihovih minijatura."

