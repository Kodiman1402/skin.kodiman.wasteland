msgstr "Mogu se forsirati samo pogledi koji nisu označeni kao onemogućeni."

msgctxt "#31418"
msgid "Don't force views"
msgstr "Ne forsirajte poglede"

msgctxt "#31419"
msgid "Forced view"
msgstr "Prisilni pogled"

msgctxt "#31420"
msgid "Enable or disable views"
msgstr "Omogućite ili onemogućite prikaze"

msgctxt "#31422"
msgid "No embedded subs"
msgstr "Nema ugrađenih titlova"

msgctxt "#31423"
msgid "Auto-open audio/subtitle selector at video start"
msgstr "Automatsko otvaranje birača zvuka/titlova pri pokretanju videa"

msgctxt "#31424"
msgid "Automatically opens an audio and subtitle selector when starting playback of movies and episodes, allowing you to see which tracks are active and change them directly before continuing."
msgstr "Automatski otvara birač zvuka i titlova prilikom pokretanja reprodukcije filmova i epizoda, omogućujući vam da vidite koji su zapisi aktivni i promijenite ih izravno prije nastavka."

msgctxt "#31425"
msgid "Search music video links for songs not in your library"
msgstr "Pretražujte veze glazbenih video zapisa za pjesme koje nisu u vašoj knjižnici"

msgctxt "#31426"
msgid "Similar artists on your library"
msgstr "Slični izvođači u vašoj knjižnici"

msgctxt "#31435"
msgid "Albums by this artist in your library"
msgstr "Albumi ovog izvođača u vašoj knjižnici"

msgctxt "#31436"
msgid "Online info from TheAudioDB.com for music"
msgstr "Online informacije s TheAudioDB.com za glazbu"

msgctxt "#31437"
msgid "Get online information from TheAudioDB.com on the artist and album information screen"
msgstr "Dobijte online informacije s TheAudioDB.com na zaslonu s informacijama o izvođaču i albumu"

msgctxt "#31438"
msgid "TheAudioDb Helper supplies online data and artwork to display enhanced details for artists and music albums."
msgstr "TheAudioDb Helper pruža online podatke i umjetnička djela za prikaz poboljšanih detalja za izvođače i glazbene albume."

msgctxt "#31439"
msgid "Record label"
msgstr "Diskografska kuća"

msgctxt "#31440"
msgid "Last.fm Plays"
msgstr "Last.fm svira"
