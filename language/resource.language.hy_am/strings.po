msgctxt "#31397"
msgid "User reviews"
msgstr "Օգտագործողների ակնարկներ"

msgctxt "#31398"
msgid "Horizontal Home menu"
msgstr "Հորիզոնական Գլխավոր մենյու"

msgctxt "#31399"
msgid "Simple Home menu"
msgstr "Պարզ Գլխավոր մենյու"

msgctxt "#31403"
msgid "Widget type"
msgstr "Վիջեթի տեսակը"

msgctxt "#31404"
msgid "Small widgets..."
msgstr "Փոքր վիդջեթներ..."

msgctxt "#31408"
msgid "Fullscreen widgets..."
msgstr "Ամբողջ էկրանով վիջեթներ..."

msgctxt "#31411"
msgid "Force view..."
msgstr "Պարտադիր դիտում..."

msgctxt "#31416"
msgid "A view can't be disabled when is selected as \"forced\" for some media."
msgstr "Դիտումը չի կարող անջատվել, երբ որոշ լրատվամիջոցների համար ընտրված է որպես \"պարտադիր\":"

msgctxt "#31417"
msgid "Only views that are not marked as disabled can be forced."
msgstr "Միայն այն դիտումները, որոնք նշված չեն որպես անջատված, կարող են պարտադրվել:"

msgctxt "#31418"
msgid "Don't force views"
msgstr "Մի պարտադրեք տեսակետները"

msgctxt "#31419"
msgid "Forced view"
msgstr "Հարկադիր դիտում"

msgctxt "#31420"
msgid "Enable or disable views"
msgstr "Միացնել կամ անջատել դիտումները"

msgctxt "#31422"
msgid "No embedded subs"
msgstr "Ներկառուցված ենթագրեր չկան"

msgctxt "#31423"
msgid "Auto-open audio/subtitle selector at video start"
msgstr "Ավտոմատ բացել աուդիո/ենթագրերի ընտրիչը տեսանյութի սկզբում"

msgctxt "#31424"
msgid "Automatically opens an audio and subtitle selector when starting playback of movies and episodes, allowing you to see which tracks are active and change them directly before continuing."
msgstr "Ֆիլմերի և դրվագների նվագարկումը սկսելիս ավտոմատ կերպով բացում է աուդիո և ենթագրերի ընտրիչը՝ թույլ տալով տեսնել, թե որ հետքերը ակտիվ են և փոխել դրանք անմիջապես՝ շարունակելուց առաջ:"

msgctxt "#31425"
msgid "Search music video links for songs not in your library"
msgstr "Որոնեք երաժշտական տեսահոլովակների հղումներ այն երգերի համար, որոնք ձեր գրադարանում չեն"

msgctxt "#31426"
msgid "Similar artists on your library"
msgstr "Նմանատիպ նկարիչներ ձեր գրադարանում"

msgctxt "#31435"
msgid "Albums by this artist in your library"
msgstr "Այս նկարչի ալբոմները ձեր գրադարանում"

msgctxt "#31436"
msgid "Online info from TheAudioDB.com for music"
msgstr "Առցանց տեղեկատվություն TheAudioDB.com-ից երաժշտության համար"

msgctxt "#31437"
msgid "Get online information from TheAudioDB.com on the artist and album information screen"
msgstr "Ստացեք առցանց տեղեկատվություն TheAudioDB.com-ից նկարչի և ալբոմի տեղեկատվության էկրանին"

msgctxt "#31438"
msgid "TheAudioDb Helper supplies online data and artwork to display enhanced details for artists and music albums."
msgstr "TheAudioDb Helper-ը տրամադրում է առցանց տվյալներ և ստեղծագործություններ՝ նկարիչների և երաժշտական ալբոմների համար ընդլայնված մանրամասներ ցուցադրելու համար:"

msgctxt "#31439"
msgid "Record label"
msgstr "Ձայնագրման լեյբլ"

msgctxt "#31440"
msgid "Last.fm Plays"
msgstr "Last.fm Նվագում է"
