msgctxt "#31230"
msgid "Choose another video file to play when Kodi starts instead of Aeon Tajo default. It's recommended to choose a short one. To stop playback and start using Kodi right away, click or press any arrow key."
msgstr "Ընտրեք մեկ այլ վիդեո ֆայլ՝ խաղալու համար, երբ Kodi-ն սկսվում է Aeon Tajo-ի կանխադրվածի փոխարեն:Խորհուրդ է տրվում ընտրել կարճ:Նվագարկումը դադարեցնելու և Kodi-ն անմիջապես օգտագործելու համար սեղմեք կամ սեղմեք ցանկացած սլաք ստեղն։"

msgctxt "#31231"
msgid "Plays an intro video when launching Kodi"
msgstr "Կոդին գործարկելիս ներածական տեսանյութ է նվագարկում"

msgctxt "#31232"
msgid "Clear current intro video file and back to default"
msgstr "Մաքրել ընթացիկ ներածական վիդեո ֆայլը և վերադարձնել լռելյայն"

msgctxt "#31233"
msgid "Clear the intro video file selected by the user and back to Aeon Tajo's default."
msgstr "Մաքրել օգտագործողի կողմից ընտրված ներածական վիդեո ֆայլը և վերադառնալ Aeon Tajo-ի կանխադրվածին:"

msgctxt "#31234"
msgid "Adds a layer that simulates falling snow on all Kodi screens, with four available intensity levels."
msgstr "Ավելացնում է շերտ, որը նմանեցնում է ձյունը իջնելը Kodi-ի բոլոր էկրաններին՝ ինտենսիվության չորս հասանելի մակարդակներով:"

msgctxt "#31235"
msgid "Override the current home menu backgrounds with this one"
msgstr "Անտեսեք ընթացիկ հիմնական ընտրացանկի նախապատմությունները այս մեկով"

msgctxt "#31236"
msgid "The background selections made in the Setup Main Menu screen will be preserved. Disabling this option will restore all previous backgrounds. This option is particularly designed for use during special seasons."
msgstr "Setup Main Menu էկրանում կատարված ֆոնային ընտրությունները կպահպանվեն:Եթե ​​անջատեք այս տարբերակը, կվերականգնվեն բոլոր նախորդ ֆոները:Այս տարբերակը հատկապես նախատեսված է հատուկ սեզոնների ժամանակ օգտագործելու համար:"

msgctxt "#31237"
msgid "No impact"
msgstr "Ոչ մի ազդեցություն"

msgctxt "#31238"
msgid "Very small"
msgstr "Շատ փոքր"

msgctxt "#31239"
msgid "Small"
msgstr "Փոքրիկ"

msgctxt "#31240"
msgid "Moderate"
msgstr "Չափավոր"

msgctxt "#31241"
msgid "Pixel format"
msgstr "Pixel ձևաչափը"

msgctxt "#31242"
msgid "System rendering speed"
msgstr "Համակարգի մատուցման արագություն"

msgctxt "#31243"
msgid "Hide actor's thumbnails"
msgstr "Թաքցնել դերասանի մանրապատկերները"

msgctxt "#31244"
msgid "Show only a list of the actors' names, instead of also including their thumbnails."
msgstr "Ցուցադրել միայն դերասանների անունների ցանկը՝ նրանց մանրապատկերները ներառելու փոխարեն:"

msgctxt "#31250"
msgid "Automatic Full Screen when playing music"
msgstr "Ավտոմատ ամբողջական էկրան երաժշտություն նվագարկելիս"

msgctxt "#31251"
msgid "Don't play melodies while in Home Screen"
msgstr "Հիմնական էկրանին մեղեդիներ մի նվագարկեք"

msgctxt "#31252"
msgid "Always show home screen widgets"
msgstr "Միշտ ցուցադրեք հիմնական էկրանի վիջեթները"

msgctxt "#31253"
msgid "Choose user audio playlist *.m3u (max.10 songs)"
msgstr "Ընտրեք օգտվողի աուդիո երգացանկ *.m3u (առավելագույնը 10 երգ)"

msgctxt "#31254"
msgid "Clear user playlist (back to default)"
msgstr "Մաքրել օգտվողի երգացանկը (վերադառնալ լռելյայն)"

msgctxt "#31300"
