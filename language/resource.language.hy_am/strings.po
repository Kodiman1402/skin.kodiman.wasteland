msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Անհատականացրեք հիմնական ընտրացանկը վիդջեթներով, նախապատմություններով և վիճակագրությամբ:Ավելացրեք ձեր սեփական հիմնական ընտրացանկի տարրերը:"

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Aeon Tajo հիմնական մենյուի ուղղահայաց դիրքը"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Փոխեք հիմնական ընտրացանկի ուղղահայաց դիրքը:Կանխադրվածը կենտրոնացած է էկրանին:"

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Հորիզոնական ցուցակների նավարկության ոճը"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Փոխեք հորիզոնական ցուցակների ոլորման եղանակը Aeon Tajo-ում:Կանխադրվածը ոլորելու է ցուցակները ցիկլով:\"Fixed\"-ը սկիզբ և վերջ ունեցող ցուցակներ են:"

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Երբ միացված է տեքստը ինքնաբերաբար պտտվում է:Երբ անջատված ձեռքով ոլորումը պահանջվում է:Նկատի ունեցեք, որ տեքստային տուփերի մեծ մասը չունի ձեռքով կոճակ:"

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Նախագծում է ընթացիկ նվագարկվող տեսանյութը վահանակների հետևի ֆոնի վրա:"

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Նախագծում է վիզուալիզացիան վահանակների հետևում գտնվող ֆոնի վրա, երբ երաժշտություն է հնչում:"

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Ցուցադրում է հիմնական էկրանին վիջեթ՝ մեդիա տեղեկատվության հետ, երբ երաժշտություն է հնչում:"

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Ցուցադրում է հիմնական էկրանին վիջեթ՝ մեդիա տեղեկատվությամբ, երբ ցուցադրվում է ֆիլմ կամ դրվագ:"

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Սա հնարավորություն է տալիս հատուկ ժանրային ֆոներ՝ տեսագրադարանի ժանրային հանգույցը դիտելիս:Ֆայլերի անունները պետք է համապատասխանեն ժանրի պիտակին:Ընդլայնումը պետք է լինի .jpg:"

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Սահմանեք կանխադրված ընտրության գործողություն՝ այս տարրը միացնելու համար:"

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Սա հնարավորություն է տալիս հատուկ ժանրային նախադրյալներ՝ երաժշտական գրադարանի ժանրային հանգույցը թերթելիս:Ֆայլերի անունները պետք է համապատասխանեն ժանրի պիտակին:Ընդլայնումը պետք է լինի .jpg:"

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Ընտրեք նախադրված ֆոներից մեկը կամ ձեր սեփական պատկերները դրեք որպես ընտրացանկի տարրերի ֆոն:"

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Ընտրեք հավելումներ, երգացանկեր կամ ընտրյալներ:Ընտրեք «Պատվիրված» Kodi-ի ներկառուցված գործառույթներից որևէ մեկի համար:(http://kodi.wiki/?title=Ներկառուցված_գործառույթների_ցանկ)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Վերականգնում է վերը նշված բոլոր արժեքները իրենց նախնական արժեքներին:"

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo հիմնական մենյուի դասավորությունը"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Այս պարամետրը սահմանում է, թե որքան տարրեր տեսանելի կլինեն հիմնական ընտրացանկում:Տարբերակները 3 հատ կամ 5 հատ են։"

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Ընտրեք վիջեթ՝ հիմնական էկրանին ցուցադրելու համար՝ գրադարանի բովանդակությանը հեշտ մուտք ունենալու համար:"

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Տեսանյութի սյուժեի նախապատվությունը"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Ցուցադրել սյուժեի ուրվագիծը գրադարանի դիտումներում և ամբողջական սյուժեն՝ տեսանյութի տեղեկատվության երկխոսության մեջ կամ հակառակը:Ընկնում է ամբողջական սյուժեի վրա, եթե ուրվագիծ չկա:"

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Ընտրեք տարր՝ հիմնական ցանկի վերևի ձախ մասում ցուցադրելու համար"

