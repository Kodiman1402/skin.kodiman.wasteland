msgid "Available audio tracks"
msgstr "Հասանելի աուդիո հետքեր"

msgctxt "#31317"
msgid "Set Fanart Path"
msgstr "Սահմանեք Fanart ուղին"

msgctxt "#31320"
msgid "Last Logged In"
msgstr "Վերջին մուտքը"

msgctxt "#31321"
msgid "Karaoke Song Selector"
msgstr "Կարաոկե երգի ընտրիչ"

msgctxt "#31328"
msgid "Recently Added"
msgstr "Վերջերս ավելացված"

msgctxt "#31331"
msgid "Installed"
msgstr "Տեղադրված է"

msgctxt "#31332"
msgid "Not Installed"
msgstr "Տեղադրված չէ"

msgctxt "#31334"
msgid "Required"
msgstr "Պահանջվում է"

msgctxt "#31335"
msgid "Recommended"
msgstr "Առաջարկվում է"

