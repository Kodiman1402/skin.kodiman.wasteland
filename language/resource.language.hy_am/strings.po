msgstr "Երաժշտություն դիտելիս ավտոմատ նվագարկեք երգերը"

msgctxt "#31261"
msgid "Enable automatic playback of songs from the current artist or album as background music while browsing music views."
msgstr "Միացրեք ընթացիկ կատարողի կամ ալբոմի երգերի ավտոմատ նվագարկումը որպես ֆոնային երաժշտություն՝ դիտելիս երաժշտության դիտումները:"

msgctxt "#31262"
msgid "Set path to use another melodies music folder"
msgstr "Սահմանեք մեղեդիների այլ երաժշտական պանակ օգտագործելու ուղին"

msgctxt "#31263"
msgid "Clear current path and back to default melodies music folder"
msgstr "Մաքրել ընթացիկ ուղին և վերադառնալ լռելյայն մեղեդիների երաժշտական պանակ"

msgctxt "#31264"
msgid "Play melodies while in Home & Settings screens"
msgstr "Նվագարկեք մեղեդիներ, երբ գտնվում եք Հիմնական և Կարգավորումների էկրաններում"

msgctxt "#31265"
msgid "Show only background"
msgstr "Ցույց տալ միայն ֆոն"

msgctxt "#31266"
msgid "TheMovieDb Helper provides data to display online ratings and additional information for movies and TV shows"
msgstr "TheMovieDb Helper-ը տրամադրում է տվյալներ՝ առցանց վարկանիշները և լրացուցիչ տեղեկություններ ֆիլմերի և հեռուստահաղորդումների համար"

msgctxt "#31267"
msgid "Show online ratings for movies and TV shows"
msgstr "Ցույց տալ առցանց վարկանիշները ֆիլմերի և հեռուստահաղորդումների համար"

msgctxt "#31268"
msgid "You have to restart Kodi for this option to take effect once the option has been activated. TMDb and Trakt should work out of the box. Metacritic and Rottentomatoes ratings require an OMDb API key. Get an OMDb API Key at http://www.omdbapi.com/apikey.aspx and afterward input the OMDb API Key into the TheMovieDb Helper settings."
msgstr "Դուք պետք է վերագործարկեք Kodi-ն, որպեսզի այս տարբերակն ուժի մեջ մտնի տարբերակն ակտիվացնելուց հետո:TMDb-ն և Trakt-ը պետք է դուրս գան:Metacritic-ի և Rottentomatoes-ի վարկանիշները պահանջում են OMDb API բանալի:Ստացեք OMDb API բանալի http://www.omdbapi.com/apikey.aspx կայքում և այնուհետև մուտքագրեք OMDb API բանալի TheMovieDb Օգնականի կարգավորումներում:"

msgctxt "#31269"
msgid "Resource image addon for displaying coloured studio icons throughout the skin."
msgstr "Ռեսուրսային պատկերի հավելում` գունավոր ստուդիայի պատկերակները ամբողջ մաշկի վրա ցուցադրելու համար:"

msgctxt "#31270"
msgid "Show colour icons for audio/video information"
msgstr "Ցույց տալ գունավոր պատկերակները աուդիո/վիդեո տեղեկատվության համար"

msgctxt "#31271"
msgid "Show extra features for movies and TV shows"
msgstr "Ցույց տալ լրացուցիչ հնարավորություններ ֆիլմերի և հեռուստահաղորդումների համար"

msgctxt "#31272"
msgid "Display the additional features (media files) placed by the user in the 'extras' folder for a movie or TV show. Remember to modify your advancedsettings.xml file if needed."
msgstr "Ցուցադրել լրացուցիչ գործառույթները (մեդիա ֆայլերը), որոնք տեղադրվել են օգտագործողի կողմից ֆիլմի կամ հեռուստահաղորդման համար «լրացուցիչ» թղթապանակում:Հիշեք, որ անհրաժեշտության դեպքում փոփոխեք ձեր advancedsettings.xml ֆայլը:"

msgctxt "#31273"
msgid "Show extras"
msgstr "Ցույց տալ հավելյալները"

msgctxt "#31274"
msgid "Enable shifting colours effect in the default Aeon Tajo's background"
msgstr "Միացնել գույների փոփոխման էֆեկտը լռելյայն Aeon Tajo-ի ֆոնին"

msgctxt "#31275"
msgid "Activate a shifting colours effect in the default Aeon Tajo's background (only in the Home screen)."
msgstr "Ակտիվացրեք փոփոխվող գույների էֆեկտը կանխադրված Aeon Tajo-ի ֆոնում (միայն հիմնական էկրանում):"

msgctxt "#31276"
msgid "Name of user's additional features folder (if different to 'extras')"
msgstr "Օգտատիրոջ լրացուցիչ հնարավորությունների թղթապանակի անվանումը (եթե տարբերվում է «լրացուցիչներից»)"

msgctxt "#31277"
msgid "Select image to show as background instead of default"
msgstr "Ընտրեք պատկերը՝ որպես ֆոն ցուցադրելու համար՝ կանխադրվածի փոխարեն"

msgctxt "#31278"
msgid "Browse for image"
msgstr "Թերթիր պատկերի համար"

msgctxt "#31279"
msgid "Play music videos"
msgstr "Նվագարկել երաժշտական տեսահոլովակներ"

msgctxt "#31280"
msgid "Play local albums"
msgstr "Նվագարկել տեղական ալբոմներ"

msgctxt "#31281"
msgid "Play songs"
msgstr "Երգեր նվագել"

msgctxt "#31282"
msgid "Blurred album image as background"
msgstr "Լղոզված ալբոմի պատկերը որպես ֆոն"

msgctxt "#31283"
msgid "Browse for path"
msgstr "Փնտրեք ուղին"

msgctxt "#31284"
msgid "Show extra features for music albums"
msgstr "Ցույց տալ լրացուցիչ հնարավորություններ երաժշտական ալբոմների համար"

msgctxt "#31285"
msgid "Display the additional features (media files) placed by the user in the 'extras' folder for a music album. Remember to modify your advancedsettings.xml file if needed."
msgstr "Ցուցադրել լրացուցիչ գործառույթները (մեդիա ֆայլեր), որոնք տեղադրված են օգտատիրոջ կողմից երաժշտական ալբոմի «լրացուցիչ» պանակում:Հիշեք, որ անհրաժեշտության դեպքում փոփոխեք ձեր advancedsettings.xml ֆայլը:"

msgctxt "#31286"
msgid "When you browse the video views and pause on a movie or TV show for a few seconds, the main theme automatically plays in the background. This feature requires the user to place an mp3 file with the theme in the root folder of the movie or TV show. This file must be named theme.mp3."
msgstr "Երբ դիտում եք տեսանյութի դիտումները և մի քանի վայրկյան դադար եք տալիս ֆիլմի կամ հեռուստահաղորդման վրա, հիմնական թեման ավտոմատ կերպով նվագարկվում է հետին պլանում:Այս հատկությունը պահանջում է, որ օգտագործողը տեղադրի mp3 ֆայլ՝ թեմայով ֆիլմի կամ հեռուստահաղորդման հիմնական թղթապանակում:Այս ֆայլը պետք է անվանվի theme.mp3:"

msgctxt "#31287"
msgid "Shows the normal poster (poster.jpg) in movies and TV shows views."
msgstr "Ցույց է տալիս սովորական պաստառը (poster.jpg) ֆիլմերում և հեռուստահաղորդումների դիտումներում:"

msgctxt "#31288"
msgid "Shows the animated poster (animatedposter.gif) in movies and TV shows views."
msgstr "Ցույց է տալիս անիմացիոն պաստառը (animatedposter.gif) ֆիլմերում և հեռուստահաղորդումների դիտումներում:"

msgctxt "#31289"
msgid "Shows the available extra posters (poster1.jpg, poster2.jpg, poster3.jpg...) in movies and TV shows views."
msgstr "Ցույց է տալիս հասանելի լրացուցիչ պաստառները (poster1.jpg, poster2.jpg, poster3.jpg...) ֆիլմերում և հեռուստահաղորդումների դիտումներում:"

msgctxt "#31290"
msgid "Thanks for using Aeon Tajo—I really hope you’re enjoying it. Creating and maintaining a Kodi skin like this takes hundreds of hours of work. If Aeon Tajo is something you enjoy and find useful, supporting it helps me keep working on it and ensures it can continue evolving in the future. [CR][CR]If you decide to do so, you’ll receive frequent updates with new features and bug fixes, along with videos, media packs, and easy-to-follow articles with detailed tips to help you get the most out of everything Aeon Tajo has to offer, together with my sincere gratitude for your support. [CR][CR]For more information, visit [B][COLOR=themecolor]patreon.com[/B][/COLOR] and search for the creator [COLOR=themecolor][B]Aeon Tajo[/B][/COLOR], or go to [COLOR=themecolor][B]patreon.com/aeontajo[/B][/COLOR].[CR][CR]Thanks!"
msgstr "Շնորհակալություն Aeon Tajo-ն օգտագործելու համար, ես իսկապես հուսով եմ, որ դուք վայելում եք այն:Նման Kodi մաշկի ստեղծումն ու պահպանումը հարյուրավոր ժամերի աշխատանք է պահանջում:Եթե ​​Aeon Tajo-ն ձեզ դուր է գալիս և օգտակար եք համարում, դրա աջակցությունն օգնում է ինձ շարունակել աշխատել դրա վրա և երաշխավորել, որ այն կարող է շարունակել զարգանալ ապագայում:[CR][CR]Եթե որոշեք դա անել, դուք հաճախակի թարմացումներ կստանաք նոր գործառույթներով և վրիպակների շտկմամբ, ինչպես նաև տեսանյութեր, մեդիա փաթեթներ և հեշտությամբ հետևող հոդվածներ՝ մանրամասն խորհուրդներով, որոնք կօգնեն ձեզ առավելագույն օգուտ քաղել այն ամենից, ինչ առաջարկում է Aeon Tajo-ն, ինչպես նաև իմ անկեղծ երախտագիտությունը ձեր աջակցության համար:[CR][CR]Լրացուցիչ տեղեկությունների համար այցելեք [B][COLOR=themecolor]patreon.com[/B][/COLOR] և որոնեք ստեղծողին [COLOR=themecolor][B]Aeon Tajo[/B][/COLOR], կամ անցեք [COLOR=themecolor][B]patreon.com/B/CR][han."

