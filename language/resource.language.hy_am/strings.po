msgstr "Ընտրովի"

msgctxt "#31390"
msgid "Skin default"
msgstr "Մաշկի լռելյայն"

msgctxt "#31400"
msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]ԿԱՐԳԱՎՈՐԵԼ Ինտերֆեյսի ԿԱՐԳԱՎՈՐՈՒՄՆԵՐԸ[/B][CR][CR]Փոխել մաշկը · Սահմանել լեզուն և տարածաշրջանը · Կարգավորել հեռակառավարման վահանակները[CR]Ստեղծել էկրանապահիչ"

msgctxt "#31401"
msgid "Menu - press 'OK'"
msgstr "Մենյու - սեղմեք «OK»"

msgctxt "#31402"
msgid "Enable startup video intro"
msgstr "Միացնել մեկնարկային տեսանյութի ներածությունը"

msgctxt "#31405"
msgid "[B]MONITOR YOUR SYSTEM[/B][CR][CR]Check out your hardware · Monitor CPU usage[CR]Check Kodi revision number"
msgstr "[B]ԴԻՏԵՔ ՁԵՐ ՀԱՄԱԿԱՐԳԸ[/B][CR][CR]Ստուգեք ձեր սարքավորումը · Վերահսկեք պրոցեսորի օգտագործումը[CR]Ստուգեք Kodi-ի վերանայման համարը"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]ԿԱՐԳԱՎՈՐԵԼ ՀԱՄԱԿԱՐԳԻ ԿԱՐԳԱՎՈՐՈՒՄՆԵՐԸ[/B][CR][CR]Կարգավորել և չափավորել էկրանները · Կարգավորել աուդիո ելքը · [CR]Սահմանել էներգախնայողության ընտրանքները · Միացնել վրիպազերծումը"

msgctxt "#31407"
msgid "[B]SETUP PROFILES[/B][CR][CR]Setup and manage user profiles · Enable login screen[CR]Change password · Add a profile picture"
msgstr "[B]SETUP PROFILES[/B][CR][CR]Կարգավորել և կառավարել օգտվողի պրոֆիլները · Միացնել մուտքի էկրանը[CR]Փոխել գաղտնաբառը · Ավելացնել պրոֆիլի նկար"

msgctxt "#31409"
msgid "[B]CONFIGURE TV SETTINGS[/B][CR][CR]Change full screen info · Manage EPG data settings"
msgstr "[B]ԿԱՐԳԱՎՈՐԵԼ հեռուստացույցի կարգավորումները[/B][CR][CR]Փոխել ամբողջ էկրանի տվյալները · Կառավարել EPG տվյալների կարգավորումները"

msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]ԿԱՐԳԱՎՈՐԵԼ ԾԱՌԱՅՈՒԹՅԱՆ ԿԱՐԳԱՎՈՐՈՒՄՆԵՐԸ[/B][CR][CR]Կարգավորել Kodi-ի կառավարումը UPnP-ի և HTTP-ի միջոցով · Կարգավորել ֆայլերի փոխանակումը[CR]Միացնել Zeroconf · Կարգավորել AirPlay-ը"

msgctxt "#31412"
msgid "Select section"
msgstr "Ընտրեք բաժինը"

msgctxt "#31413"
msgid "Local subtitle available"
msgstr "Տեղական ենթագրերը հասանելի են"

msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]ԿԱՐԳԱՎՈՐԵԼ ՆՎԱՃԱՌՔԻ ԿԱՐԳԱՎՈՐՈՒՄՆԵՐԸ[/B][CR][CR]Կարգավորել տեսանյութի նվագարկումը · Կարգավորել երաժշտության նվագարկումը · Կարգավորել նկարի սլայդերի ցուցադրումը[CR]Կարգավորել տեսանյութի լեզուն և ենթագրերը"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]ԿԱՐԳԱՎՈՐԵԼ ՄԵԴԻԱ ԿԱՐԳԱՎՈՐՈՒՄՆԵՐԸ[/B][CR][CR]Սահմանել կանխադրված ընտրված գործողությունը · Կարգավորել ֆայլերի ցանկի ընտրանքները · Կարգավորել մետատվյալների ընտրանքները[CR]Կառավարել տվյալների բազաները"

msgctxt "#31421"
msgid "Select your Kodi user profile[CR]to login and continue"
msgstr "Մուտք գործելու և շարունակելու համար ընտրեք ձեր Kodi օգտվողի պրոֆիլը[CR]"

msgctxt "#31427"
msgid "Skin Shortcuts is responsible for handling all aspects of the main menu."
msgstr "Skin Shortcuts-ը պատասխանատու է հիմնական ընտրացանկի բոլոր ասպեկտների համար:"

msgctxt "#31428"
msgid "The Grab Fanart script provides the random fanart slideshows for the main menu."
msgstr "Grab Fanart սկրիպտը ապահովում է fanart-ի պատահական սլայդ-ցուցադրումներ հիմնական ցանկի համար:"

msgctxt "#31429"
msgid "Library Data Provider is a service that runs in the background to provide library data for widgets and live backgrounds as well as playlist statistics for infolines."
msgstr "Գրադարանային տվյալների մատակարարը ծառայություն է, որն աշխատում է հետին պլանում՝ վիջեթների և կենդանի ֆոնի համար գրադարանային տվյալներ տրամադրելու, ինչպես նաև ինֆոգծերի երգացանկերի վիճակագրություն տրամադրելու համար:"

msgctxt "#31430"
msgid "Resource image addon for displaying the default white studio icons throughout the skin."
msgstr "Ռեսուրսային պատկերի հավելում մաշկի վրա լռելյայն սպիտակ ստուդիայի պատկերակները ցուցադրելու համար:"

msgctxt "#31431"
msgid "Resource image addon for displaying the default white recording label icons throughout the skin."
msgstr "Ռեսուրսային պատկերի հավելում` լռելյայն սպիտակ ձայնագրող պիտակի պատկերակները ամբողջ մաշկի վրա ցուցադրելու համար:"

msgctxt "#31432"
msgid "Provides numerous Widget options and extended cast and crew metadata."
msgstr "Ապահովում է Widget-ի բազմաթիվ տարբերակներ և ընդլայնված դերասանական և անձնակազմի մետատվյալներ:"

msgctxt "#31433"
msgid "Skin Info Service is used to display movie set information throughout the skin."
msgstr "Skin Info Service-ն օգտագործվում է ամբողջ մաշկի վրա ֆիլմերի մասին տեղեկատվությունը ցուցադրելու համար:"

msgctxt "#31434"
msgid "Check MP3 Theme checks whether the user has put a theme.mp3 file in the corresponding movie/TV show folder to be played when browsing."
msgstr "Ստուգեք MP3 թեման ստուգում է, թե արդյոք օգտատերը տեղադրել է theme.mp3 ֆայլը համապատասխան ֆիլմի/հեռուստատեսային շոուի թղթապանակում՝ դիտելիս:"

msgctxt "#31450"
msgid "  •  Open Settings "
msgstr "• Բացեք Պարամետրերը"

msgctxt "#31451"
msgid "  •  Click to Install"
msgstr "• Սեղմեք՝ Տեղադրելու համար"

msgctxt "#31473"
msgid "Aeon Tajo Helper provides the data to display the cast for movies and TV shows."
msgstr "Aeon Tajo Helper-ը տրամադրում է տվյալներ ֆիլմերի և հեռուստահաղորդումների դերասանական կազմը ցուցադրելու համար:"

msgctxt "#31474"
msgid "CU LRC Lyrics is used to download, sync, and display lyrics during fullscreen music playback."
msgstr "CU LRC Lyrics-ն օգտագործվում է տեքստերը ներբեռնելու, համաժամացնելու և ցուցադրելու համար ամբողջ էկրանով երաժշտության նվագարկման ժամանակ:"

msgctxt "#31475"
msgid "Play Trailer makes possible to play movie trailers through a context menu. "
msgstr "Play Trailer-ը հնարավորություն է տալիս ֆիլմերի թրեյլերներ նվագարկել համատեքստի ընտրացանկի միջոցով:"

msgctxt "#31476"
msgid "Allows the use of Youtube to play trailers and other videos."
msgstr "Թույլ է տալիս YouTube-ի օգտագործումը՝ թրեյլերներ և այլ տեսանյութեր նվագարկելու համար:"

msgctxt "#31477"
msgid "Provides some cast actress images to be shown in video views."
msgstr "Տրամադրում է դերասանուհու որոշ կերպարներ, որոնք կցուցադրվեն տեսանյութերի դիտումներում:"

msgctxt "#31478"
msgid "Artist Slideshow is used to display artist fanart for both the home screen and during fullscreen music playback."
msgstr "Artist Slideshow-ն օգտագործվում է նկարչի ֆանարտը ցուցադրելու համար և՛ հիմնական էկրանին, և՛ ամբողջ էկրանով երաժշտության նվագարկման ժամանակ:"

msgctxt "#31479"
msgid "AutoCompletion provides suggestions to be selected while using the virtual keyboard."
msgstr "Ավտոմատ լրացումն ապահովում է առաջարկներ, որոնք պետք է ընտրվեն վիրտուալ ստեղնաշարն օգտագործելիս:"

msgctxt "#31480"
