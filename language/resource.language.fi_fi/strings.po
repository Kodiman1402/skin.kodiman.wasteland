msgid "Channel Options"
msgstr "Kanavan valinnat"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Näytä samanlaisia elokuvia hyllyn 3D-näkymässä"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "36 tunnin ennuste"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Tuntiennuste"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Viikonlopun ennuste"

msgctxt "#31904"
msgid "10 Day Forecast"
msgstr "10 paivän ennuste"

msgctxt "#31908"
msgid "Chance of Precipitation"
msgstr "Sateen mahdollisuus"

msgctxt "#31909"
msgid "Fetching forecast info..."
msgstr "Noudetaan ennustetietoja..."

msgctxt "#31910"
msgid "Map & Alerts"
msgstr "Kartta ja hälytykset"

msgctxt "#31911"
msgid "Setup the Aeon Tajo main menu"
msgstr "Määritä päävalikko"

msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Mukauta päävalikkoa widgeteillä, taustoilla ja tilastoilla. Lisää päävalikkoon omia kohteita."

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Päävalikon pystysijainti"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Muuta päävalikon pystysijaintia. Oletus on keskitetty."

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Vaakalistausten selaustapa"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Muuta vaakasuuntaisten listojen selaustapaa. Oletusarvoisesti listat ovat päättymättömiä. \"Kiinteä\" tarkoittaa listaa, jossa on alku ja loppu."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Kun käytössä, teksti rullaa automaattisesti.Kun pois käytöstä, manuaalinen vieritys vaaditaan.Huomaa, että useimmissa tekstilaatikoissa ei ole manuaalista painiketta."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Näyttää toistettavan videon taustana, paneelien takana."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Näyttää toistettavan musiikin visualisoinnin taustana, paneelien takana."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Näyttää aloitusnäytössä widgetin toistettavan musiikin tiedoilla."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Näyttää aloitusnäytössä widgetin toistettavan elokuvan tai jakson tiedoilla."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Ottaa videokirjaston lajityyppejä selattaessa näytettävät, mukautetut lajityyppikohtaiset taustat käyttöön. Tiedostonimien tulee vastata lajityypin nimeä. Tiedostopäätteen tulee olla .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Aseta oletustoiminto valittaessa saadaksesi tämän käyttöön."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Ottaa musiikkikirjaston lajityyppejä selattaessa näytettävät, mukautetut lajityyppikohtaiset taustat käyttöön. Tiedostonimien tulee vastata lajityypin nimeä. Tiedostopäätteen tulee olla .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Valitse joku esiasetetuista taustakuvista tai valitse omat kuvat valikkonimikkeiden taustakuviksi."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Valitse lisäosat, soittolistat tai suosikit. Valitse 'Mukautettu' asettaaksesi minkä tahansa Kodi:n sisäänrakennetuista toiminnoista. (http://kodi.wiki/?title=List_of_Built_In_Functions)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Palauta ylläolevien valintojen oletusarvot."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Päävalikon asettelu"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Tämä asetus määrittää kuinka monta nimikettä on yhtäaikaa näkyvissä päävalikossa . Vaihtoehdot on 3 tai 5."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Valitse aloitusnäytössä näytettävä widgetti tavoittaaksesi kirjastosi sisällön helposti."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Videon juonen esitystapa"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Näytä juonen pääpiirteet kirjaston näkymissä ja täysi juoni videotiedot-ikkunassa tai toisinpäin. Täysi juoni näytetään jos pääpiirteitä ei ole saatavilla."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Valitse päävalikossa ylävasemmalla näytettävä kohde"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Vaihda paikkaa toisen päävalikon nimikkeen kanssa. Avaa ikkunan jossa on lista valikkonimikkeistä."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "Näytä RSS-syöte ruudun alalaidassa päävalikon sijainnista riippuen. Tämä tekee alivalikosta pysyvästi näkyvän."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "Ottaa käytöön lisätiedot tv-sarjakirjastossa. Sisältää tv-sarjan tilan, tulevan / viimeisimmän jakson jne. On riippuvainen \"Next Aired\" -lisäosasta."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "Piilota infopaneeli vieritettäessä"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "Piilottaa infopaneelin Näyteikkuna ja Vaakakuva näytöissä selattaessa kirjastoa (jos aktivoitu). Aseta kuinka monta sekuntia odotetaan ennenkuin infopaneeli tulee näkyviin kun vieritys on lopetettu."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "Kioskitila"

msgctxt "#31942"
msgid "Disables the slide out menu (media menu) in the library as well as certain buttons in the media information dialogs. (Requires restart to take effect)"
msgstr "Ottaa pois käytöstä liukuvan valikon (mediavalikko) kirjastossa kuten myös tietyt painikkeet mediatiedot -ikkunoissa. (Asetuksen muuttaminen vaatii uudelleenkäynnistuksen)"

msgctxt "#31943"
msgid "Watched status indicator"
msgstr "Katsotantilan indikaattori"

msgctxt "#31944"
msgid "Choose which overlays to show on thumbs in icon based views. Note that the \"Resume\" flag takes precedent over any watched status."
msgstr "Valitse mitä osoittimia näytetään thumb:ien päällä ikoneihin perustuvissa näytöissä. Huomaa että \"Jatka\" lippu on määräävämpi mihin tahansa katsottu -tilaan nähden."

msgctxt "#31945"
msgid "This toggles the layout of the List view. Default is a 7 item layout with extended info, \"Slim List\" is a 14 item, more basic layout"
msgstr "Vaihtaa listanäkymän asettelua. Oletus on 7-nimikkeen asettelu ExtendedInfo-tiedoilla. \"Tiivis lista\" näyttää vähemmän tietoja, mutta 14 nimikettä."

