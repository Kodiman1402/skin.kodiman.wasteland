msgstr "Grupos[CR] Disponiveis"

msgctxt "#31511"
msgid "Channel Options"
msgstr "Opções do canal"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Mostrar filmes semelhantes na vista Shelf 3D"

