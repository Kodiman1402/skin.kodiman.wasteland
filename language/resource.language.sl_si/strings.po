msgctxt "#31400"
msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]KONFIGURIRAJTE NASTAVITVE VMESNIKA[/B][CR][CR]Spremenite preobleko · Nastavite jezik in regijo · Nastavite daljinske upravljalnike[CR]Nastavite ohranjevalnik zaslona · Nastavite glavno zaklepanje"

msgctxt "#31401"
msgid "Menu - press 'OK'"
msgstr "Meni - pritisnite "OK""

msgctxt "#31402"
msgid "Enable startup video intro"
msgstr "Omogoči zagonski video uvod"

msgctxt "#31405"
msgid "[B]MONITOR YOUR SYSTEM[/B][CR][CR]Check out your hardware · Monitor CPU usage[CR]Check Kodi revision number"
msgstr "[B]SPREMLJAJTE SVOJ SISTEM[/B][CR][CR]Preverite svojo strojno opremo · Spremljajte uporabo procesorja[CR]Preverite številko revizije Kodi"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]KONFIGURACIJA SISTEMSKIH NASTAVITEV[/B][CR][CR]Nastavitev in umerjanje zaslonov · Konfiguracija zvočnega izhoda · [CR]Nastavitev možnosti varčevanja z energijo · Omogočanje odpravljanja napak"

msgctxt "#31407"
msgid "[B]SETUP PROFILES[/B][CR][CR]Setup and manage user profiles · Enable login screen[CR]Change password · Add a profile picture"
msgstr "[B]NASTAVITEV PROFILOV[/B][CR][CR]Nastavite in upravljajte uporabniške profile · Omogoči prijavni zaslon[CR]Spremenite geslo · Dodajte sliko profila"

msgctxt "#31409"
msgid "[B]CONFIGURE TV SETTINGS[/B][CR][CR]Change full screen info · Manage EPG data settings"
msgstr "[B]PRILAGODITVE NASTAVITVE TV[/B][CR][CR]Spremenite informacije v celozaslonskem načinu · Upravljajte z nastavitvami EPG"

msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]PRILAGODITE NASTAVITVE STORITEV[/B][CR][CR]Nastavite upravljanje Kodi preko UPnP in HTTP · Nastavite deljenje datotek[CR]Vključite Zeroconf · Prilagodite AirPlay"

msgctxt "#31412"
msgid "Select section"
msgstr "Izberite razdelek"

msgctxt "#31413"
msgid "Local subtitle available"
msgstr "Na voljo so krajevni podnapisi"

msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]KONFIGURIRAJTE NASTAVITVE PREDVAJALNIKA[/B][CR][CR]Konfigurirajte predvajanje videa · Konfigurirajte predvajanje glasbe · Konfigurirajte diaprojekcijo slik[CR]Konfigurirajte jezik videa in podnapise"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]KONFIGURIRAJTE NASTAVITVE PREDSTAVNOSTI[/B][CR][CR]Nastavite privzeto dejanje izbire · Konfigurirajte možnosti seznama datotek · Konfigurirajte možnosti metapodatkov[CR]Upravljanje baz podatkov"

msgctxt "#31421"
msgid "Select your Kodi user profile[CR]to login and continue"
msgstr "Izberite svoj Kodi uporabniški profil[CR]za prijavo in nadaljevanje"

msgctxt "#31427"
msgid "Skin Shortcuts is responsible for handling all aspects of the main menu."
msgstr "Skin Shortcuts je odgovoren za upravljanje vseh vidikov glavnega menija."

msgctxt "#31428"
msgid "The Grab Fanart script provides the random fanart slideshows for the main menu."
msgstr "Skript Grab Fanart zagotavlja naključne diaprojekcije fanart za glavni meni."

msgctxt "#31429"
msgid "Library Data Provider is a service that runs in the background to provide library data for widgets and live backgrounds as well as playlist statistics for infolines."
msgstr "Library Data Provider je storitev, ki deluje v ozadju in zagotavlja knjižnične podatke za gradnike in ozadja v živo ter statistiko seznamov predvajanja za informacijske vrstice."

msgctxt "#31430"
msgid "Resource image addon for displaying the default white studio icons throughout the skin."
msgstr "Dodatek za sliko vira za prikaz privzetih belih studijskih ikon po celotni preobleki."

msgctxt "#31431"
msgid "Resource image addon for displaying the default white recording label icons throughout the skin."
msgstr "Dodatek za sliko vira za prikaz privzetih belih ikon snemalne nalepke po celotni preobleki."

msgctxt "#31432"
msgid "Provides numerous Widget options and extended cast and crew metadata."
msgstr "Ponuja številne možnosti pripomočkov in razširjene metapodatke o zasedbi in ekipi."

msgctxt "#31433"
msgid "Skin Info Service is used to display movie set information throughout the skin."
msgstr "Skin Info Service se uporablja za prikaz informacij o prizorišču filma po celotni preobleki."

msgctxt "#31434"
msgid "Check MP3 Theme checks whether the user has put a theme.mp3 file in the corresponding movie/TV show folder to be played when browsing."
msgstr "Preveri temo MP3 preveri, ali je uporabnik dal datoteko theme.mp3 v ustrezno mapo filma/TV-oddaje, ki se predvaja med brskanjem."

msgctxt "#31450"
msgid "  •  Open Settings "
msgstr "• Odprite Nastavitve"

msgctxt "#31451"
msgid "  •  Click to Install"
msgstr "• Kliknite za namestitev"

msgctxt "#31473"
msgid "Aeon Tajo Helper provides the data to display the cast for movies and TV shows."
msgstr "Aeon Tajo Helper zagotavlja podatke za prikaz igralske zasedbe za filme in TV-oddaje."

msgctxt "#31474"
msgid "CU LRC Lyrics is used to download, sync, and display lyrics during fullscreen music playback."
msgstr "CU LRC Lyrics se uporablja za prenos, sinhronizacijo in prikaz besedil med celozaslonskim predvajanjem glasbe."

msgctxt "#31475"
msgid "Play Trailer makes possible to play movie trailers through a context menu. "
msgstr "Play Trailer omogoča predvajanje filmskih napovednikov prek kontekstnega menija."

msgctxt "#31476"
msgid "Allows the use of Youtube to play trailers and other videos."
msgstr "Omogoča uporabo YouTuba za predvajanje napovednikov in drugih videoposnetkov."

msgctxt "#31477"
msgid "Provides some cast actress images to be shown in video views."
msgstr "Zagotavlja nekaj slik igralcev, ki bodo prikazane v ogledih videoposnetkov."

msgctxt "#31478"
msgid "Artist Slideshow is used to display artist fanart for both the home screen and during fullscreen music playback."
msgstr "Diaprojekcija izvajalcev se uporablja za prikaz oboževalcev izvajalcev tako na začetnem zaslonu kot med celozaslonskim predvajanjem glasbe."

msgctxt "#31479"
msgid "AutoCompletion provides suggestions to be selected while using the virtual keyboard."
msgstr "Samodokončanje ponuja predloge, ki jih je treba izbrati med uporabo virtualne tipkovnice."

msgctxt "#31480"
msgid "Library Editor Script uses JSON to directly edit your database information."
msgstr "Skript urejevalnika knjižnice uporablja JSON za neposredno urejanje podatkov vaše zbirke podatkov."

msgctxt "#31481"
msgid "Global Search makes possible to search among all the items (movies, TV shows, music, actors, etc.) in your collection."
msgstr "Globalno iskanje omogoča iskanje med vsemi predmeti (filmi, TV-oddaje, glasba, igralci itd.) v vaši zbirki."

msgctxt "#31501"
msgid "Channel group"
msgstr "Skupina programa"

