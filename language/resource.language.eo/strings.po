msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B]Agordu SERVAVAJROJN[/B][CR][CR]Agordu kontrolon de Kodi per UPnP kaj HTTP · Agordi dosierdividon[CR]Ebligi Zeroconf · Agordi AirPlay"

