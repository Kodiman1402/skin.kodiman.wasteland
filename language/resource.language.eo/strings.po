msgstr "Loka subtitolo havebla"

msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]Agordu ludantajn agordojn[/B][CR][CR]Agordu videoludadon · Agordi muzikludadon · Agordi bildan bildaron[CR]Agordu videolingvon kaj subtekstojn"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]Agordu Agordojn pri komunikiloj[/B][CR][CR]Agordu defaŭltan elektan agon · Agordi dosierlistopciojn · Agordi metadatumojn[CR]Administri datumbazojn"

