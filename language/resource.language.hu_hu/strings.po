msgid "Reset skin default background"
msgstr "A bőr alapértelmezett hátterének visszaállítása"

msgctxt "#31214"
msgid "Resets the default background provided with Aeon Tajo."
msgstr "Visszaállítja az Aeon Tajo által biztosított alapértelmezett hátteret."

msgctxt "#31215"
msgid "Show the coloured version of the icons rather than the monochrome version."
msgstr "Az ikonok színes változatát jelenítse meg a monokróm változat helyett."

msgctxt "#31216"
msgid "Displays background and fanart images with a subtle motion effect across the screen."
msgstr "Megjeleníti a hátteret és a fanart képeket finom mozgási hatással a képernyőn."

msgctxt "#31217"
msgid "Displays a list in the video views featuring thumbnail images of the main actors from the movie or TV show's cast."
msgstr "Listát jelenít meg a videónézetekben, amely a film vagy a tévéműsor szereplőinek főszereplőinek miniatűrjeit tartalmazza."

msgctxt "#31218"
msgid "Search the Studio Icons add-on for logo images of the film studios of the movie/TV show, and if found, display them while browsing the video views."
msgstr "Keressen a Studio Icons bővítményben a film/tévéműsor filmstúdióinak logóképeit, és ha megtalálja, jelenítse meg őket a videonézetek böngészése közben."

msgctxt "#31219"
msgid "Search for the album's record label logo using the RecordLabel Icons addon, and if found, display it when browsing the music album views."
msgstr "Keresse meg az album lemezkiadó logóját a RecordLabel Icons bővítmény segítségével, és ha megtalálja, jelenítse meg a zenei albumnézetek böngészésekor."

msgctxt "#31220"
