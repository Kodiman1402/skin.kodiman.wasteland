msgctxt "#31414"
msgid "[B]CONFIGURE PLAYER SETTINGS[/B][CR][CR]Configure video playback · Configure music playback · Configure picture slideshow[CR]Configure video language and subtitles"
msgstr "[B]LEJÁTSZÓ BEÁLLÍTÁSOK KONFIGURÁLÁSA[/B][CR][CR]Videolejátszás konfigurálása · Zenelejátszás konfigurálása · Képes diavetítés konfigurálása[CR]Videó nyelvének és feliratainak konfigurálása"

msgctxt "#31415"
msgid "[B]CONFIGURE MEDIA SETTINGS[/B][CR][CR]Set default select action · Configure file list options · Configure metadata options[CR]Manage databases"
msgstr "[B]MÉDIABEÁLLÍTÁSOK KONFIGURÁLÁSA[/B][CR][CR]Alapértelmezett kiválasztási művelet beállítása · Fájllista-beállítások konfigurálása · Metaadat-beállítások konfigurálása[CR]Adatbázisok kezelése"

msgctxt "#31421"
msgid "Select your Kodi user profile[CR]to login and continue"
msgstr "Válaszd ki a Kodi felhasználói profilod[CR]a belépéshez"

msgctxt "#31427"
msgid "Skin Shortcuts is responsible for handling all aspects of the main menu."
msgstr "A Skin Shortcuts felelős a főmenü minden aspektusának kezeléséért."

msgctxt "#31428"
msgid "The Grab Fanart script provides the random fanart slideshows for the main menu."
msgstr "A Grab Fanart szkript biztosítja a véletlenszerű fanart diavetítéseket a főmenüben."

msgctxt "#31429"
msgid "Library Data Provider is a service that runs in the background to provide library data for widgets and live backgrounds as well as playlist statistics for infolines."
msgstr "A Library Data Provider egy olyan szolgáltatás, amely a háttérben fut, hogy könyvtári adatokat biztosítson widgetekhez és élő hátterekhez, valamint lejátszási listastatisztikát az információs vonalakhoz."

msgctxt "#31430"
msgid "Resource image addon for displaying the default white studio icons throughout the skin."
msgstr "Erőforrás képkiegészítő az alapértelmezett fehér stúdióikonok teljes felületen való megjelenítéséhez."

msgctxt "#31431"
msgid "Resource image addon for displaying the default white recording label icons throughout the skin."
msgstr "Erőforrás képkiegészítő az alapértelmezett fehér felvételi címke ikonok megjelenítéséhez a bőrön."

msgctxt "#31432"
msgid "Provides numerous Widget options and extended cast and crew metadata."
msgstr "Számos widget-beállítást és kiterjesztett szereplő- és stáb metaadatokat biztosít."

msgctxt "#31433"
msgid "Skin Info Service is used to display movie set information throughout the skin."
msgstr "A Skin Info Service a filmkészlet információinak a bőrön való megjelenítésére szolgál."

msgctxt "#31434"
msgid "Check MP3 Theme checks whether the user has put a theme.mp3 file in the corresponding movie/TV show folder to be played when browsing."
msgstr "Az MP3 téma ellenőrzése ellenőrzi, hogy a felhasználó elhelyezett-e theme.mp3 fájlt a megfelelő film/TV-műsor mappába, hogy böngészés közben lejátszhassa."

msgctxt "#31450"
msgid "  •  Open Settings "
msgstr "  • Beállítások megnyitása "

msgctxt "#31451"
msgid "  •  Click to Install"
msgstr "• Kattintson a telepítéshez"

msgctxt "#31473"
msgid "Aeon Tajo Helper provides the data to display the cast for movies and TV shows."
msgstr "Az Aeon Tajo Helper biztosítja az adatokat a filmek és tévéműsorok szereplőinek megjelenítéséhez."

msgctxt "#31474"
msgid "CU LRC Lyrics is used to download, sync, and display lyrics during fullscreen music playback."
msgstr "A CU LRC Lyrics a dalszövegek letöltésére, szinkronizálására és megjelenítésére szolgál teljes képernyős zenelejátszás közben."

msgctxt "#31475"
msgid "Play Trailer makes possible to play movie trailers through a context menu. "
msgstr "A Play Trailer lehetővé teszi a filmelőzetesek lejátszását a helyi menün keresztül."

msgctxt "#31476"
msgid "Allows the use of Youtube to play trailers and other videos."
msgstr "Lehetővé teszi a Youtube használatát előzetesek és egyéb videók lejátszására."

msgctxt "#31477"
msgid "Provides some cast actress images to be shown in video views."
msgstr "Néhány színésznő-képet biztosít, amelyek megjelennek a videónézetben."

msgctxt "#31478"
msgid "Artist Slideshow is used to display artist fanart for both the home screen and during fullscreen music playback."
msgstr "Az Artist Slideshow az előadói fanart megjelenítésére szolgál mind a kezdőképernyőn, mind a teljes képernyős zenelejátszás során."

msgctxt "#31479"
msgid "AutoCompletion provides suggestions to be selected while using the virtual keyboard."
msgstr "Az Automatikus kiegészítés javaslatokat ad a virtuális billentyűzet használata közben."

msgctxt "#31480"
msgid "Library Editor Script uses JSON to directly edit your database information."
msgstr "A Library Editor Script a JSON segítségével közvetlenül szerkeszti az adatbázis adatait."

msgctxt "#31481"
msgid "Global Search makes possible to search among all the items (movies, TV shows, music, actors, etc.) in your collection."
msgstr "A Global Search lehetővé teszi a keresést a gyűjteményében található összes elem (filmek, tévéműsorok, zenék, színészek stb.) között."

msgctxt "#31501"
msgid "Channel group"
msgstr "Csatornacsoport"

msgctxt "#31502"
msgid "Live TV"
msgstr "Élő TV"

msgctxt "#31503"
msgid "Add Group"
msgstr "Csoport hozzáadása"

msgctxt "#31504"
msgid "Rename Group"
msgstr "Csoport átnevezése"

msgctxt "#31505"
msgid "Delete Group"
msgstr "Csoport törlése"

msgctxt "#31506"
msgid "Available[CR]Groups"
msgstr "Elérhető[CR]Csoportok"

msgctxt "#31511"
msgid "Channel Options"
msgstr "Csatorna opciók"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Hasonló filmek megjelenítése Polc 3D nézetben"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "36 órás előrejelzés"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Előrejelzés óránként"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Hétvégi előrejelzés"

msgctxt "#31904"
msgid "10 Day Forecast"
msgstr "10 napos előrejelzés"

msgctxt "#31908"
msgid "Chance of Precipitation"
msgstr "Csapadék esélye"

msgctxt "#31909"
msgid "Fetching forecast info..."
msgstr "Előrejelzési információ letöltése..."

msgctxt "#31910"
msgid "Map & Alerts"
msgstr "Térkép & Riasztások"

msgctxt "#31911"
msgid "Setup the Aeon Tajo main menu"
msgstr "Az Aeon Tajo főmenü beállítása"

msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Testreszabhatja a főmenüt widgetekkel, hátterekkel és statisztikákkal.Adja hozzá saját egyéni főmenüpontjait."

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Az Aeon Tajo főmenü függőleges helyzete"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Módosítsa a főmenü függőleges helyzetét.Az alapértelmezett a képernyő közepén."

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Navigációs stílus vízszintes listákhoz"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Módosítsa a vízszintes listák gördülési módját az Aeon Tajoban.Az alapértelmezett egy ciklusban görgeti a listákat.A \"Rögzített\" olyan listák, amelyeknek kezdete és vége van."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Ha engedélyezve van, a szöveg automatikusan gördül.Ha letiltja, kézi görgetésre van szükség.Vegye figyelembe, hogy a legtöbb szövegdoboznak nincs kézi gombja."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Az aktuálisan lejátszott videót a háttérre vetíti a panelek mögé."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Zene lejátszásakor a vizualizációt a panelek mögötti háttérre vetíti."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Zenelejátszás közben egy widgetet jelenít meg a kezdőképernyőn médiainformációkkal."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Film vagy epizód lejátszása közben egy widgetet jelenít meg a kezdőképernyőn médiainformációkkal."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Ez lehetővé teszi az egyéni műfaji háttereket, amikor a videokönyvtár műfaji csomópontjában böngészik.A fájlneveknek meg kell egyeznie a műfaji címkével.A kiterjesztésnek .jpg formátumúnak kell lennie."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Állítson be egy alapértelmezett kiválasztási műveletet az elem engedélyezéséhez."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Ez lehetővé teszi az egyéni műfaji háttereket a zenei könyvtár műfaji csomópontjának böngészésekor.A fájlneveknek meg kell egyeznie a műfaji címkével.A kiterjesztésnek .jpg formátumúnak kell lennie."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Válasszon egyet az előre beállított hátterek közül, vagy állítsa be saját képeit a menüelemek háttereként."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Válasszon kiegészítőket, lejátszási listákat vagy kedvenceket.Válassza az „Egyéni” lehetőséget a Kodi bármelyik beépített funkciójához.(http://kodi.wiki/?title=List_of_Built_In_Functions)"

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Az összes fenti értéket visszaállítja az alapértelmezett értékükre."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo főmenü elrendezése"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Ez a beállítás határozza meg, hogy mennyi elem lesz látható a főmenüben.Választható: 3 vagy 5 elem."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Válassza ki a kezdőképernyőn megjelenítendő widgetet, hogy könnyen hozzáférhessen a könyvtár tartalmához."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Videó cselekmény preferenciája"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "A cselekmény körvonalának megjelenítése a könyvtári nézetekben és a teljes cselekmény megjelenítése a videoinformációs párbeszédpanelen, vagy fordítva.Visszaesik a teljes cselekményre, ha nem áll rendelkezésre vázlat."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Válassza ki a főmenü bal felső részén megjelenítendő elemet"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Helyet váltani egy másik menüponttal.Megnyit egy párbeszédpanelt a választható menüelemek listájával."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
