msgid "Channel Options"
msgstr "Kanalindstillinger"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Vis lignende film i Shelf 3D-visning"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "36 timers vejrudsigt"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Vejrudsigt de næste timer"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Vejrudsigt for weekenden"

msgctxt "#31904"
msgid "10 Day Forecast"
msgstr "10 døgns vejrudsigt"

msgctxt "#31908"
msgid "Chance of Precipitation"
msgstr "Risiko for nedbør"

msgctxt "#31909"
msgid "Fetching forecast info..."
msgstr "Henter vejrudsigt..."

msgctxt "#31910"
msgid "Map & Alerts"
msgstr "Kort og advarsler"

msgctxt "#31911"
msgid "Setup the Aeon Tajo main menu"
msgstr "Konfigurer Aeon Tajo-startmenuen"

msgctxt "#31912"
msgid "Customize the main menu with widgets, backgrounds and statistics. Add your own custom main menu items."
msgstr "Tilpas startmenuen med widgets, baggrunde og statistik. Tilføj dine egne tilpassede startmenupunkter."

msgctxt "#31913"
msgid "Aeon Tajo main menu vertical position"
msgstr "Aeon Tajo startmenuens lodrette position"

msgctxt "#31914"
msgid "Change the vertical position of the main menu. Default is centered on screen."
msgstr "Skift den lodrette position af startmenuen. Standard er centreret på skærmen."

msgctxt "#31915"
msgid "Navigation style for horizontal lists"
msgstr "Navigationsstil for vandrette lister"

msgctxt "#31916"
msgid "Change the way horizontal lists scroll in Aeon Tajo. Default will scroll lists in a cycle. \"Fixed\" are lists with a beginning and end."
msgstr "Skift den måde, vandrette lister ruller på i Aeon Tajo. Standard ruller lister i en cyklus. \"Fast\" er lister med en begyndelse og en slutning."

msgctxt "#31917"
msgid "When enabled text scrolls automatically. When disabled manual scrolling is required. Note that most textboxes don't have a manual button."
msgstr "Når aktiveret, ruller tekst automatisk. Når deaktiveret, kræves manuel rulning. Bemærk, at de fleste tekstbokse ikke har en manuel knap."

msgctxt "#31918"
msgid "Projects the current playing video on the background behind the panels."
msgstr "Projicerer den aktuelt afspillede video på baggrunden bag panelerne."

msgctxt "#31919"
msgid "Projects the visualisation on the background behind the panels when music is played."
msgstr "Projicerer visualiseringen på baggrunden bag panelerne, når musik afspilles."

msgctxt "#31920"
msgid "Displays a widget on the Home screen with media information when music is playing."
msgstr "Viser en widget på startskærmen med medieoplysninger, når musik afspilles."

msgctxt "#31921"
msgid "Displays a widget on the Home screen with media information when a movie or episode is playing."
msgstr "Viser en widget på startskærmen med medieoplysninger, når en film eller episode afspilles."

msgctxt "#31922"
msgid "This enables custom genre backgrounds when browsing through the videolibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Dette aktiverer brugerdefinerede genrebaggrunde, når du gennemser videobbibliotekets genreknude. Filnavne skal matche genrebetegnelsen. Udvidelsen skal være .jpg."

msgctxt "#31923"
msgid "Set a default select action to enable this item."
msgstr "Indstil en standardvalghandling for at aktivere dette element."

msgctxt "#31924"
msgid "This enables custom genre backgrounds when browsing through the musiclibrary's genre node. Filenames should match the genre label. Extension must be .jpg."
msgstr "Dette aktiverer brugerdefinerede genrebaggrunde, når du gennemser musikbibliotekets genreknude. Filnavne skal matche genrebetegnelsen. Udvidelsen skal være .jpg."

msgctxt "#31925"
msgid "Pick one of the preset backgrounds or set your own images as the menu items background."
msgstr "Vælg en af de forudindstillede baggrunde, eller indstil dine egne billeder som baggrund for menupunkterne."

msgctxt "#31926"
msgid "Select add-ons, playlists or favourites. Choose 'Custom' for any of Kodi's built-in functions. (http://kodi.wiki/?title=List_of_Built_In_Functions)"
msgstr "Vælg tilføjelser, afspilningslister eller favoritter. Vælg 'Brugerdefineret' for en af Kodis indbyggede funktioner."

msgctxt "#31927"
msgid "Resets all above values to their defaults."
msgstr "Nulstiller alle ovenstående værdier til deres standardindstillinger."

msgctxt "#31928"
msgid "Aeon Tajo main menu layout"
msgstr "Aeon Tajo startmenulayout"

msgctxt "#31929"
msgid "This setting defines how much items will be visible on the main menu. Options are 3 items or 5 items."
msgstr "Denne indstilling definerer, hvor mange elementer der vil være synlige i startmenuen. Mulighederne er 3 eller 5 elementer."

msgctxt "#31930"
msgid "Choose a widget to display on the Home screen to have easy access to content from the library."
msgstr "Vælg en widget til visning på startskærmen for nem adgang til indhold fra biblioteket."

msgctxt "#31931"
msgid "Video plot preference"
msgstr "Videoplot-præference"

msgctxt "#31932"
msgid "Show plot outline in the library views and full plot in the video information dialog or vice versa. Falls back to full plot if no outline is available."
msgstr "Vis plotresumé i biblioteksvisningerne og fuldt plot i videoinfodialogen eller omvendt. Falder tilbage til fuldt plot, hvis intet resumé er tilgængeligt."

msgctxt "#31933"
msgid "Select an item to display on the left top of the main menu"
msgstr "Vælg et element til visning øverst til venstre i startmenuen"

msgctxt "#31935"
msgid "Switch places with another menu item. Opens a dialog with a list of menu items to choose from."
msgstr "Byt plads med et andet menupunkt. Åbner en dialog med en liste over menupunkter at vælge imellem."

msgctxt "#31937"
msgid "Show the RSS feed on the bottom or top of the screen, depending on main menu position. Enabling this setting makes the submenu permanently visible."
msgstr "Vis RSS-feedet nederst eller øverst på skærmen afhængigt af startmenuens position. Aktivering af denne indstilling gør undermenuen permanent synlig."

msgctxt "#31938"
msgid "Enables extra information in the TV show library, like TV show status, next / latest episode, etc. Depends on TV Show Next Aired add-on."
msgstr "Aktiverer ekstra oplysninger i TV-seriebiblioteket, såsom TV-seriestatus, næste/seneste episode osv. Afhænger af TV Show Next Aired-tilføjelsen."

msgctxt "#31939"
msgid "Hide Infopanel on scrolling"
msgstr "Skjul informationspanel ved rulning"

msgctxt "#31940"
msgid "Hides the infopanel for Showcase and Landscape view (if activated) while scrolling through the library. Set the amount of seconds to wait for the infopanel to appear when scrolling is stopped."
msgstr "Skjuler infopanelet for Showcase og Landscape-visning (hvis aktiveret), mens du gennemser biblioteket. Indstil antallet af sekunder til at vente på, at infopanelet vises, når rulningen stoppes."

msgctxt "#31941"
msgid "Kiosk mode"
msgstr "Kiosktilstand"

msgctxt "#31942"
msgid "Disables the slide out menu (media menu) in the library as well as certain buttons in the media information dialogs. (Requires restart to take effect)"
msgstr "Deaktiverer udtrækningsmenuen (mediemenuen) i biblioteket samt bestemte knapper i medieinformationsdialogerne. (Kræver genstart for at træde i kraft)"

msgctxt "#31943"
msgid "Watched status indicator"
msgstr "Setsindikator for senstatus"

msgctxt "#31944"
msgid "Choose which overlays to show on thumbs in icon based views. Note that the \"Resume\" flag takes precedent over any watched status."
msgstr "Vælg, hvilke overlays der skal vises på miniaturebilleder i ikonbaserede visninger. Bemærk, at \"Genoptag\"-flaget har forrang frem for enhver senstatus."

msgctxt "#31945"
msgid "This toggles the layout of the List view. Default is a 7 item layout with extended info, \"Slim List\" is a 14 item, more basic layout"
msgstr "Dette skifter layoutet af listevisningen. Standard er et 7-elements layout med udvidede oplysninger, \"Slim List\" er et 14-elements, mere grundlæggende layout."

