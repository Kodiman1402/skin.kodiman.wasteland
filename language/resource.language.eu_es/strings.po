msgctxt "#31410"
msgid "[B]CONFIGURE SERVICE SETTINGS[/B][CR][CR]Setup control of Kodi via UPnP and HTTP · Configure file sharing[CR]Enable Zeroconf · Configure AirPlay"
msgstr "[B] KONFIGURTU ZERBITZUAREN EZARPENAK[/B][CR][CR]Konfiguratu Kodiren kontrola UPnP eta HTTP bidez · Konfiguratu fitxategiak partekatzea[CR]Gaitu Zeroconf · Konfiguratu AirPlay"

