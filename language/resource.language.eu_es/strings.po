msgstr "[B]BEGIRATU ZURE SISTEMA[/B][CR][CR]Egiaztatu zure hardwarea · Monitorizatu PUZaren erabilera[CR]Begiratu Kodiren berrikuspen-zenbakia"

msgctxt "#31406"
msgid "[B]CONFIGURE SYSTEM SETTINGS[/B][CR][CR]Setup and calibrate displays · Configure audio output · [CR]Set power saving options · Enable debugging"
msgstr "[B]CONFIGURATU SISTEMAREN EZARPENAK[/B][CR][CR]Konfiguratu eta kalibratu pantailak · Audio-irteera konfiguratu · [CR]Ezarri energia aurrezteko aukerak · Gaitu arazketa"

msgctxt "#31407"
