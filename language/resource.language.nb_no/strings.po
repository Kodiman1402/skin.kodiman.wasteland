msgctxt "#31400"
msgid "[B]CONFIGURE INTERFACE SETTINGS[/B][CR][CR]Change the skin · Set language and region · Setup remote controls[CR]Set up a screensaver · Setup master lock"
msgstr "[B]KONFIGURER GRENSESNITTINNSTILLINGER[/B][CR][CR]Endre skinn · Angi språk og region · Konfigurer fjernkontroller[CR]Sett opp en skjermsparer · Konfigurer hovedlås"

msgctxt "#31401"
