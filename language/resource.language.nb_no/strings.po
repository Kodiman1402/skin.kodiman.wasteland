msgid "Channel Options"
msgstr "Kanal instillinger"

msgctxt "#31512"
msgid "Show similar movies in Shelf 3D view"
msgstr "Vis lignende filmer i hylle 3D-visning"

msgctxt "#31901"
msgid "36 Hour Forecast"
msgstr "36-timersvarsel"

msgctxt "#31902"
msgid "Hourly Forecast"
msgstr "Time for time"

msgctxt "#31903"
msgid "Weekend Forecast"
msgstr "Helgevarsel"

